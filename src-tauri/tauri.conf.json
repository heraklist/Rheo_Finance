{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rheo Finance",
  "version": "0.2.24",
  "identifier": "app.rheo.finance",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rheo Finance",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://ipc.localhost https://*.supabase.co wss://*.supabase.co https://api.github.com https://github.com https://objects.githubusercontent.com https://raw.githubusercontent.com https://landing-two-dun-95.vercel.app; img-src 'self' asset: http://asset.localhost data: blob: https://*.supabase.co; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Rheo",
    "copyright": "Copyright © 2026 Heraklis. All rights reserved.",
    "category": "Finance",
    "shortDescription": "Local-first finance for independent professionals",
    "longDescription": "Native app for freelancers, small businesses, and independent professionals to track income, expenses, receipts, VAT, and cashflow. Local-first with cloud sync."
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:evochia.db"]
    },
    "updater": {
      "endpoints": ["https://landing-two-dun-95.vercel.app/api/update/desktop"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1RDQ3OTcwMDJEMkMyMjEKUldRaHd0SUNjSG5VVlhrV0JHTmhCd0VibXBjVW5VWlZ0REVoRzFGSUVsNnJjUXZKYkVoUUdjeUYK"
    }
  }
}
