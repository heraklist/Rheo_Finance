{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Evochia Finance",
  "version": "0.2.2",
  "identifier": "gr.evochia.finance",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Finance",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://ipc.localhost https://*.supabase.co wss://*.supabase.co; img-src 'self' asset: http://asset.localhost data: blob: https://*.supabase.co; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Evochia",
    "copyright": "© 2026 Heraklis · Evochia",
    "category": "Finance",
    "shortDescription": "Local-first διαχείριση οικονομικών",
    "longDescription": "Native app για διαχείριση των οικονομικών του Evochia (επαγγελματικά + προσωπικά). Local-first με sync σε cloud."
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:evochia.db"]
    },
    "updater": {
      "endpoints": [
        "https://github.com/heraklist/evochia_finance/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCRDQ4NEU3ODJCMThGQTMKUldTamo3R0M1NFRVbXhmWHpVM0hVeDNQNG53L0VTT0FTdzRKck1ERzFmQytUZkJvd3ZpQVBqL1MK"
    }
  }
}
