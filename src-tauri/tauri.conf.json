{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rheo Finance",
  "version": "0.2.26",
  "identifier": "app.rheo.finance",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rheo Finance",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co https://landing-two-dun-95.vercel.app; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Rheo Finance",
    "copyright": "Copyright © 2026 Rheo Finance",
    "category": "Finance",
    "shortDescription": "Local-first finance management for independent professionals",
    "longDescription": "Rheo Finance is a local-first finance management app for independent professionals.",
    "windows": {
      "wix": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "installerHooks": "installer.nsh"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://landing-two-dun-95.vercel.app/api/download?manifest=desktop"],
      "pubkey": "RUSjj7GC54TUm/sK63kGiREp4eSr9g0Fc40PYNiCeg7tjuMoYop1t4fYMNKlTqQc0BAgMnPfylGCdRaocxXB5bgWUDtGmksuLwY="
    }
  }
}
