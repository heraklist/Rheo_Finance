{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Evochia Finance",
  "version": "0.1.0",
  "identifier": "gr.evochia.finance",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Finance",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Evochia",
    "copyright": "© 2026 Heraklis · Evochia",
    "category": "Finance",
    "shortDescription": "Local-first διαχείριση οικονομικών",
    "longDescription": "Native app για διαχείριση των οικονομικών του Evochia (επαγγελματικά + προσωπικά). Local-first με sync σε cloud."
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://finance.evochia.gr/update/{{target}}/{{current_version}}"],
      "dialog": true,
      "pubkey": ""
    },
    "sql": {
      "preload": ["sqlite:evochia.db"]
    }
  }
}
