{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Evochia Finance",
  "platforms": ["windows", "macOS", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "stronghold:default",
    "stronghold:allow-remove-store-record",
    "updater:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/receipts/**" },
        { "path": "$DOCUMENT/Evochia_Backups" },
        { "path": "$DOCUMENT/Evochia_Backups/**" }
      ]
    },
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-exists",
    "os:allow-platform",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close"
  ]
}
