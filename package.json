{
  "name": "rheo-finance",
  "private": true,
  "version": "0.2.27",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "description": "Rheo Finance - local-first finance management for independent professionals",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset --local",
    "supabase:test": "supabase test db --local",
    "supabase:lint": "supabase db lint --local",
    "supabase:types": "supabase gen types typescript --local > src/lib/database.types.ts",
    "db:check": "pnpm supabase:reset && pnpm supabase:lint && pnpm supabase:test && pnpm supabase:types",
    "security:secrets": "gitleaks detect --source . --verbose",
    "security:semgrep": "semgrep scan --config auto .",
    "security:pnpm-audit": "pnpm audit --audit-level high",
    "security:pnpm-audit:landing": "pnpm --dir landing audit --audit-level high",
    "security:cargo-audit": "cd src-tauri && cargo audit",
    "security:audit": "pnpm security:pnpm-audit && pnpm security:pnpm-audit:landing && pnpm security:cargo-audit",
    "quality:all": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-shell": "~2.3.5",
    "@tauri-apps/plugin-sql": "~2.4.0",
    "@tauri-apps/plugin-stronghold": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
