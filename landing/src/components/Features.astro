---
const features = [
  {
    icon: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>`,
    title: "Έσοδα & Έξοδα",
    desc: "Smart defaults, αυτόματος ΦΠΑ, κατηγοριοποίηση ανά βιβλίο.",
    mockup: "dashboard",
  },
  {
    icon: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
    title: "Επαναλαμβανόμενα",
    desc: "Πάγια, ενοίκια, συνδρομές — template και αυτοματισμός.",
    mockup: "recurring",
  },
  {
    icon: `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>`,
    title: "ΦΠΑ Τριμήνου",
    desc: "Αυτόματη σύνοψη ΦΠΑ. Δες τι χρωστάς χωρίς spreadsheet.",
    mockup: "vat",
  },
  {
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
    title: "Προβλέψεις 12 μηνών",
    desc: "Πρόβλεψη βάσει ιστορικού. Δες πού πας πριν φτάσεις.",
    mockup: "forecast",
  },
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`,
    title: "Αποδείξεις & Φωτογραφίες",
    desc: "Φωτογράφισε αποδείξεις. Sync στο cloud, πάντα διαθέσιμες.",
    mockup: "receipts",
  },
  {
    icon: `<path d="M21.21 15.89A10 10 0 118 2.83"/><polyline points="22 2 22 12 12 12"/>`,
    title: "Offline-First",
    desc: "Δουλεύει παντού. Sync όταν βρεις WiFi.",
    mockup: "offline",
  },
];
---

<section id="features" class="border-t border-border-light py-20 md:py-24">
  <div class="section-container">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="text-h1 text-charcoal">
        Ό,τι χρειάζεσαι,<br class="hidden sm:block" /> τίποτα παραπάνω.
      </h2>
      <p class="mt-3 text-body text-text-secondary">
        Σχεδιασμένο για ελεύθερους επαγγελματίες που θέλουν ξεκάθαρα νούμερα χωρίς τη πολυπλοκότητα ενός ERP.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map(({ icon, title, desc, mockup }) => (
          <div class="feature-card group">
            <!-- CSS Mockup Preview -->
            <div class="mb-5 overflow-hidden rounded-lg border border-border-light bg-cream">
              <div class="mockup-window">
                {/* Titlebar */}
                <div class="flex items-center gap-1.5 border-b border-border-light bg-sand/60 px-3 py-2">
                  <span class="h-2 w-2 rounded-full bg-expense/40" />
                  <span class="h-2 w-2 rounded-full bg-warning/40" />
                  <span class="h-2 w-2 rounded-full bg-income/40" />
                  <span class="ml-2 text-[9px] font-medium text-text-muted">◆ Rheo</span>
                </div>

                {/* Screen content */}
                <div class="p-3" style="min-height: 120px;">
                  {mockup === "dashboard" && (
                    <div>
                      {/* KPI Row */}
                      <div class="grid grid-cols-3 gap-1.5">
                        <div class="rounded border border-income/20 bg-income/5 p-1.5">
                          <div class="text-[7px] text-text-muted">Έσοδα</div>
                          <div class="text-[11px] font-bold text-income">4.280 €</div>
                        </div>
                        <div class="rounded border border-expense/20 bg-expense/5 p-1.5">
                          <div class="text-[7px] text-text-muted">Έξοδα</div>
                          <div class="text-[11px] font-bold text-expense">1.930 €</div>
                        </div>
                        <div class="rounded border border-gold/20 bg-gold/5 p-1.5">
                          <div class="text-[7px] text-text-muted">Υπόλοιπο</div>
                          <div class="text-[11px] font-bold text-gold">2.350 €</div>
                        </div>
                      </div>
                      {/* Mini bar chart */}
                      <div class="mt-3 flex items-end gap-1" style="height: 48px;">
                        <div class="flex-1 flex flex-col items-center gap-0.5">
                          <div class="w-full rounded-t bg-income/60" style="height: 32px;" />
                          <div class="w-full rounded-t bg-expense/40" style="height: 18px;" />
                          <span class="text-[6px] text-text-muted">Ιαν</span>
                        </div>
                        <div class="flex-1 flex flex-col items-center gap-0.5">
                          <div class="w-full rounded-t bg-income/60" style="height: 38px;" />
                          <div class="w-full rounded-t bg-expense/40" style="height: 22px;" />
                          <span class="text-[6px] text-text-muted">Φεβ</span>
                        </div>
                        <div class="flex-1 flex flex-col items-center gap-0.5">
                          <div class="w-full rounded-t bg-income/60" style="height: 28px;" />
                          <div class="w-full rounded-t bg-expense/40" style="height: 16px;" />
                          <span class="text-[6px] text-text-muted">Μαρ</span>
                        </div>
                        <div class="flex-1 flex flex-col items-center gap-0.5">
                          <div class="w-full rounded-t bg-income/60" style="height: 44px;" />
                          <div class="w-full rounded-t bg-expense/40" style="height: 24px;" />
                          <span class="text-[6px] text-text-muted">Απρ</span>
                        </div>
                        <div class="flex-1 flex flex-col items-center gap-0.5">
                          <div class="w-full rounded-t bg-income/60" style="height: 36px;" />
                          <div class="w-full rounded-t bg-expense/40" style="height: 20px;" />
                          <span class="text-[6px] text-text-muted">Μαΐ</span>
                        </div>
                      </div>
                    </div>
                  )}

                  {mockup === "recurring" && (
                    <div class="space-y-1.5">
                      <div class="flex items-center justify-between rounded border border-border-light bg-white/80 px-2 py-1.5">
                        <div class="flex items-center gap-1.5">
                          <div class="h-2 w-2 rounded-full bg-expense/60" />
                          <span class="text-[9px] font-medium text-charcoal">Ενοίκιο</span>
                        </div>
                        <span class="text-[9px] font-semibold text-expense">-850 €</span>
                      </div>
                      <div class="flex items-center justify-between rounded border border-border-light bg-white/80 px-2 py-1.5">
                        <div class="flex items-center gap-1.5">
                          <div class="h-2 w-2 rounded-full bg-expense/60" />
                          <span class="text-[9px] font-medium text-charcoal">ΔΕΚΟ</span>
                        </div>
                        <span class="text-[9px] font-semibold text-expense">-180 €</span>
                      </div>
                      <div class="flex items-center justify-between rounded border border-border-light bg-white/80 px-2 py-1.5">
                        <div class="flex items-center gap-1.5">
                          <div class="h-2 w-2 rounded-full bg-income/60" />
                          <span class="text-[9px] font-medium text-charcoal">Catering</span>
                        </div>
                        <span class="text-[9px] font-semibold text-income">+2.400 €</span>
                      </div>
                      <div class="flex items-center justify-between rounded border border-border-light bg-white/80 px-2 py-1.5">
                        <div class="flex items-center gap-1.5">
                          <div class="h-2 w-2 rounded-full bg-expense/60" />
                          <span class="text-[9px] font-medium text-charcoal">Λογιστής</span>
                        </div>
                        <span class="text-[9px] font-semibold text-expense">-150 €</span>
                      </div>
                    </div>
                  )}

                  {mockup === "vat" && (
                    <div>
                      <div class="mb-2 flex items-center justify-between">
                        <span class="text-[9px] font-semibold text-charcoal">Q1 2026</span>
                        <span class="rounded-full bg-income/10 px-1.5 py-0.5 text-[7px] font-semibold text-income">Πληρωμένο</span>
                      </div>
                      <div class="space-y-1">
                        <div class="flex justify-between text-[8px]">
                          <span class="text-text-muted">ΦΠΑ Εκροών</span>
                          <span class="font-medium text-charcoal">1.027 €</span>
                        </div>
                        <div class="flex justify-between text-[8px]">
                          <span class="text-text-muted">ΦΠΑ Εισροών</span>
                          <span class="font-medium text-charcoal">463 €</span>
                        </div>
                        <div class="my-1 border-t border-border-light" />
                        <div class="flex justify-between text-[9px]">
                          <span class="font-semibold text-charcoal">Πληρωτέο</span>
                          <span class="font-bold text-expense">564 €</span>
                        </div>
                      </div>
                      <div class="mt-3 mb-1 flex items-center justify-between">
                        <span class="text-[9px] font-semibold text-charcoal">Q2 2026</span>
                        <span class="rounded-full bg-warning/10 px-1.5 py-0.5 text-[7px] font-semibold text-warning">Εκκρεμεί</span>
                      </div>
                      <div class="space-y-1">
                        <div class="flex justify-between text-[8px]">
                          <span class="text-text-muted">ΦΠΑ Εκροών</span>
                          <span class="font-medium text-charcoal">892 €</span>
                        </div>
                        <div class="flex justify-between text-[8px]">
                          <span class="text-text-muted">ΦΠΑ Εισροών</span>
                          <span class="font-medium text-charcoal">341 €</span>
                        </div>
                      </div>
                    </div>
                  )}

                  {mockup === "forecast" && (
                    <div>
                      <div class="mb-2 flex items-center justify-between">
                        <span class="text-[9px] font-semibold text-charcoal">Πρόβλεψη 12μ</span>
                        <span class="text-[8px] text-income font-medium">▲ +12%</span>
                      </div>
                      {/* Forecast line chart mockup */}
                      <svg viewBox="0 0 200 70" class="w-full" style="height: 80px;">
                        {/* Grid lines */}
                        <line x1="0" y1="17" x2="200" y2="17" stroke="#E5E0D5" stroke-width="0.5" />
                        <line x1="0" y1="35" x2="200" y2="35" stroke="#E5E0D5" stroke-width="0.5" />
                        <line x1="0" y1="52" x2="200" y2="52" stroke="#E5E0D5" stroke-width="0.5" />
                        {/* Actual data line */}
                        <polyline
                          points="0,50 28,44 56,48 84,38 112,35 140,30"
                          fill="none"
                          stroke="#2D6A4F"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                        {/* Forecast dashed line */}
                        <polyline
                          points="140,30 160,26 180,22 200,18"
                          fill="none"
                          stroke="#B8860B"
                          stroke-width="1.5"
                          stroke-dasharray="4,3"
                          stroke-linecap="round"
                        />
                        {/* Area under forecast */}
                        <polygon
                          points="140,30 160,26 180,22 200,18 200,70 140,70"
                          fill="#B8860B"
                          opacity="0.06"
                        />
                        {/* Current point */}
                        <circle cx="140" cy="30" r="3" fill="#2D6A4F" />
                      </svg>
                      <div class="flex justify-between text-[6px] text-text-muted mt-0.5">
                        <span>Ιούν</span>
                        <span>Αύγ</span>
                        <span>Οκτ</span>
                        <span>Δεκ</span>
                        <span>Φεβ</span>
                        <span>Μαΐ '27</span>
                      </div>
                    </div>
                  )}

                  {mockup === "receipts" && (
                    <div class="grid grid-cols-3 gap-1.5">
                      <div class="flex flex-col items-center gap-1 rounded border border-border-light bg-white/80 p-1.5">
                        <div class="flex h-10 w-full items-center justify-center rounded bg-sand/60">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9C9385" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                          </svg>
                        </div>
                        <span class="text-[7px] text-text-muted">Lidl</span>
                        <span class="text-[7px] font-medium text-expense">42 €</span>
                      </div>
                      <div class="flex flex-col items-center gap-1 rounded border border-border-light bg-white/80 p-1.5">
                        <div class="flex h-10 w-full items-center justify-center rounded bg-sand/60">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9C9385" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                          </svg>
                        </div>
                        <span class="text-[7px] text-text-muted">ΔΕΗ</span>
                        <span class="text-[7px] font-medium text-expense">95 €</span>
                      </div>
                      <div class="flex flex-col items-center gap-1 rounded border border-gold/30 bg-gold/5 p-1.5">
                        <div class="flex h-10 w-full items-center justify-center rounded bg-gold/10">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8860B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                          </svg>
                        </div>
                        <span class="text-[7px] font-medium text-gold">Νέα</span>
                      </div>
                    </div>
                  )}

                  {mockup === "offline" && (
                    <div>
                      <div class="mb-2 flex items-center gap-1.5">
                        <div class="flex items-center gap-1 rounded-full bg-income/10 px-2 py-0.5">
                          <div class="h-1.5 w-1.5 rounded-full bg-income" />
                          <span class="text-[7px] font-semibold text-income">Synced</span>
                        </div>
                        <span class="text-[7px] text-text-muted">3 δευτ. πριν</span>
                      </div>
                      <div class="space-y-1">
                        <div class="flex items-center justify-between rounded bg-white/80 px-2 py-1 border border-border-light">
                          <div class="flex items-center gap-1.5">
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            <span class="text-[8px] text-charcoal">Catering Μύκονος</span>
                          </div>
                          <span class="text-[8px] font-medium text-income">+3.200 €</span>
                        </div>
                        <div class="flex items-center justify-between rounded bg-white/80 px-2 py-1 border border-border-light">
                          <div class="flex items-center gap-1.5">
                            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#2D6A4F" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            <span class="text-[8px] text-charcoal">Υλικά event</span>
                          </div>
                          <span class="text-[8px] font-medium text-expense">-480 €</span>
                        </div>
                        <div class="flex items-center justify-between rounded bg-gold/5 px-2 py-1 border border-gold/20">
                          <div class="flex items-center gap-1.5">
                            <div class="h-1.5 w-1.5 rounded-full bg-gold animate-pulse" />
                            <span class="text-[8px] text-charcoal">Εξοπλισμός</span>
                          </div>
                          <span class="text-[8px] font-medium text-expense">-220 €</span>
                        </div>
                      </div>
                      <p class="mt-2 text-center text-[7px] text-text-muted">Αποθηκεύεται τοπικά · Sync αυτόματα</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* Feature info */}
            <div class="flex items-start gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gold/10">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#B8860B"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={icon}
                />
              </div>
              <div>
                <h3 class="text-h3 text-charcoal">{title}</h3>
                <p class="mt-1 text-body-sm text-text-secondary">{desc}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
