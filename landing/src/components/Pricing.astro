---
const free = [
  "1 βιβλίο (Επαγγελματικά ή Προσωπικά)",
  "Έως 50 καταχωρήσεις / μήνα",
  "Dashboard & γραφήματα",
  "ΦΠΑ τριμήνου",
  "Τοπική αποθήκευση",
  "Windows & Android",
];

const pro = [
  "Απεριόριστα βιβλία & καταχωρήσεις",
  "Cloud sync σε όλες τις συσκευές",
  "Αποδείξεις & φωτογραφίες",
  "Επαναλαμβανόμενα templates",
  "Πρόβλεψη 12 μηνών",
  "Excel export για λογιστή",
  "Backup σε Google Drive",
  "Priority support",
];
---

<section id="pricing" class="border-t border-border-light bg-sand/40 py-20 md:py-24">
  <div class="section-container">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="text-h1 text-charcoal">Απλή τιμολόγηση</h2>
      <p class="mt-3 text-body text-text-secondary">
        Ξεκίνα δωρεάν. Αναβάθμισε όταν χρειαστείς sync &amp; cloud.
      </p>

      <!-- Billing toggle -->
      <div class="mt-8 inline-flex items-center gap-3 rounded-full border border-border-light bg-white/60 px-4 py-2">
        <span id="label-monthly" class="text-body-sm font-medium text-charcoal">Μηνιαίο</span>
        <button
          id="billing-toggle"
          type="button"
          role="switch"
          aria-checked="false"
          class="relative h-6 w-11 rounded-full bg-border-mid transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
        >
          <span
            id="toggle-dot"
            class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform"
          ></span>
        </button>
        <span id="label-annual" class="text-body-sm text-text-muted">
          Ετήσιο <span class="ml-1 rounded-full bg-income/10 px-2 py-0.5 text-[11px] font-semibold text-income">-20%</span>
        </span>
      </div>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 md:gap-8">
      <!-- Free -->
      <div class="pricing-card">
        <p class="text-label uppercase tracking-widest text-text-muted">Free</p>
        <div class="mt-3 flex items-baseline gap-1">
          <span class="text-display text-charcoal">0&euro;</span>
          <span class="text-body-sm text-text-muted">/ για πάντα</span>
        </div>
        <p class="mt-2 text-body-sm text-text-secondary">
          Για να ξεκινήσεις χωρίς δέσμευση.
        </p>
        <ul class="mt-6 flex flex-col gap-2.5">
          {
            free.map((item) => (
              <li class="flex items-start gap-2 text-body-sm text-text-primary">
                <svg
                  class="mt-0.5 shrink-0"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#2D6A4F"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
        <a href="#download" class="btn-secondary mt-8 w-full">Κατέβασε δωρεάν</a>
      </div>

      <!-- Pro -->
      <div class="pricing-card-pro relative">
        <span
          class="absolute -top-3 right-6 rounded-full bg-gold px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-text-on-dark"
        >
          Δημοφιλές
        </span>
        <p class="text-label uppercase tracking-widest text-gold">Pro</p>
        <div class="mt-3 flex items-baseline gap-1">
          <span id="pro-price" class="text-display text-charcoal">5&euro;</span>
          <span id="pro-period" class="text-body-sm text-text-muted">/ μήνα</span>
        </div>
        <p id="pro-subtitle" class="mt-2 text-body-sm text-text-secondary">
          Sync, αποδείξεις, export — όλα τα εργαλεία.
        </p>
        <ul class="mt-6 flex flex-col gap-2.5">
          {
            pro.map((item) => (
              <li class="flex items-start gap-2 text-body-sm text-text-primary">
                <svg
                  class="mt-0.5 shrink-0"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#B8860B"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
        <a href="#download" class="btn-gold mt-8 w-full">Ξεκίνα με Pro</a>
        <p class="mt-2 text-center text-[11px] text-text-muted">
          Κατέβασε δωρεάν, αναβάθμισε μέσα από την εφαρμογή.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById("billing-toggle");
  const dot = document.getElementById("toggle-dot");
  const labelMonthly = document.getElementById("label-monthly");
  const labelAnnual = document.getElementById("label-annual");
  const proPrice = document.getElementById("pro-price");
  const proPeriod = document.getElementById("pro-period");
  const proSubtitle = document.getElementById("pro-subtitle");

  let annual = false;

  toggle?.addEventListener("click", () => {
    annual = !annual;
    toggle.setAttribute("aria-checked", String(annual));

    if (annual) {
      toggle.classList.replace("bg-border-mid", "bg-gold");
      dot!.style.transform = "translateX(20px)";
      labelMonthly!.classList.replace("text-charcoal", "text-text-muted");
      labelMonthly!.classList.replace("font-medium", "font-normal");
      labelAnnual!.classList.replace("text-text-muted", "text-charcoal");
      proPrice!.innerHTML = "4&euro;";
      proPeriod!.textContent = "/ μήνα";
      proSubtitle!.textContent = "48€ / έτος — εξοικονόμηση 20%.";
    } else {
      toggle.classList.replace("bg-gold", "bg-border-mid");
      dot!.style.transform = "translateX(0)";
      labelMonthly!.classList.replace("text-text-muted", "text-charcoal");
      labelMonthly!.classList.replace("font-normal", "font-medium");
      labelAnnual!.classList.replace("text-charcoal", "text-text-muted");
      proPrice!.innerHTML = "5&euro;";
      proPeriod!.textContent = "/ μήνα";
      proSubtitle!.textContent = "Sync, αποδείξεις, export — όλα τα εργαλεία.";
    }
  });
</script>
