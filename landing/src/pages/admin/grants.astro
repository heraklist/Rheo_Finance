---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Rheo Admin - Πλάνα χρηστών"
  description="Εσωτερική διαχείριση πλάνων χρηστών Rheo Finance."
>
  <main class="min-h-screen bg-cream py-10">
    <section class="section-container max-w-4xl">
      <a href="/" class="mb-8 inline-flex items-center gap-2 text-body-sm font-semibold text-gold">
        ← Πίσω στο Rheo
      </a>

      <div class="mb-8">
        <div class="mb-3 flex items-center gap-3">
          <img src="/app-icon.png" alt="" class="h-10 w-10 rounded-lg" />
          <div>
            <p class="text-body-sm font-semibold text-gold">Rheo Admin</p>
            <h1 class="text-display-sm font-bold text-charcoal">Πλάνα χρηστών</h1>
          </div>
        </div>
        <p class="max-w-2xl text-body text-text-secondary">
          Δώσε ή άλλαξε πρόσβαση Free, Solo, Pro ή Team χωρίς χρήση terminal.
        </p>
      </div>

      <div id="status" class="mb-5 hidden rounded-lg border px-4 py-3 text-body-sm"></div>

      <!-- Login panel -->
      <section id="login-panel" class="rounded-xl border border-border-light bg-white/70 p-6">
        <h2 class="mb-2 text-h2 font-bold text-charcoal">Σύνδεση admin</h2>
        <p class="mb-5 text-body-sm text-text-secondary">
          Χρησιμοποίησε τον λογαριασμό Supabase που έχει admin πρόσβαση.
        </p>

        <form id="login-form" class="grid gap-4">
          <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
            Email
            <input
              id="login-email"
              type="email"
              required
              autocomplete="email"
              class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
            />
          </label>

          <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
            Password
            <input
              id="login-password"
              type="password"
              required
              autocomplete="current-password"
              class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
            />
          </label>

          <button type="submit" class="btn-primary">Σύνδεση</button>
        </form>
      </section>

      <!-- Grant panel (visible after login) -->
      <section id="grant-panel" class="hidden space-y-6">
        <!-- Admin bar -->
        <div class="flex flex-col gap-3 rounded-xl border border-border-light bg-white/70 p-5 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-body-sm text-text-secondary">Συνδεδεμένος admin</p>
            <p id="admin-email" class="font-semibold text-charcoal"></p>
          </div>
          <button id="sign-out" type="button" class="btn-secondary !px-4 !py-2">Αποσύνδεση</button>
        </div>

        <!-- Grant form -->
        <div class="rounded-xl border border-border-light bg-white/70 p-6">
          <div class="mb-4 flex items-center justify-between">
            <h3 class="text-h3 font-bold text-charcoal" id="form-title">Νέα πρόσβαση</h3>
            <div class="flex items-center gap-2">
              <button id="form-reset" type="button" class="hidden text-xs font-semibold text-gold hover:underline">
                Καθαρισμός φόρμας
              </button>
              <button id="toggle-bulk" type="button" class="text-xs font-semibold text-text-secondary hover:text-charcoal hover:underline">
                Bulk mode
              </button>
            </div>
          </div>

          <!-- #1: Quick templates -->
          <div class="mb-4 flex flex-wrap gap-2" id="templates-bar">
            <button type="button" data-tpl="beta30" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">
              Beta tester 30η
            </button>
            <button type="button" data-tpl="solo-perm" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">
              Solo permanent
            </button>
            <button type="button" data-tpl="pro-perm" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">
              Pro permanent
            </button>
            <button type="button" data-tpl="owner" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">
              Owner (Team)
            </button>
          </div>

          <!-- Single grant form -->
          <form id="grant-form" class="grid gap-5">
            <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
              Email χρήστη
              <input
                id="grant-email"
                type="email"
                required
                autocomplete="off"
                placeholder="user@example.com"
                class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
              />
            </label>

            <div class="grid gap-4 md:grid-cols-2">
              <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
                Πλάνο
                <select
                  id="grant-tier"
                  required
                  class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
                >
                  <option value="free">Free</option>
                  <option value="solo">Solo</option>
                  <option value="pro">Pro</option>
                  <option value="team">Team</option>
                </select>
              </label>

              <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
                Τύπος πρόσβασης
                <select
                  id="grant-source"
                  required
                  class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
                >
                  <option value="manual">Manual</option>
                  <option value="tester">Tester</option>
                  <option value="owner">Owner</option>
                </select>
              </label>
            </div>

            <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
              Λήξη πρόσβασης
              <input
                id="grant-expires"
                type="datetime-local"
                class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
              />
              <span class="text-xs font-normal text-text-muted">Άφησέ το κενό για πρόσβαση χωρίς ημερομηνία λήξης.</span>
            </label>

            <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">
              Αιτιολογία
              <textarea
                id="grant-reason"
                rows="2"
                placeholder="π.χ. Beta tester access"
                class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold"
              ></textarea>
            </label>

            <button type="submit" class="btn-gold">Αποθήκευση πρόσβασης</button>
          </form>

          <!-- #2: Bulk grant form (hidden by default) -->
          <div id="bulk-panel" class="mt-5 hidden border-t border-border-light pt-5">
            <h4 class="mb-2 text-body-sm font-semibold text-charcoal">Bulk grant</h4>
            <p class="mb-3 text-xs text-text-muted">Ένα email ανά γραμμή. Θα πάρουν το tier/source/expiry από τη φόρμα πάνω.</p>
            <textarea
              id="bulk-emails"
              rows="4"
              placeholder="user1@example.com&#10;user2@example.com&#10;user3@example.com"
              class="w-full rounded-lg border border-border-mid bg-cream px-4 py-3 text-sm text-charcoal outline-none focus:border-gold"
            ></textarea>
            <div class="mt-3 flex items-center gap-3">
              <button id="bulk-submit" type="button" class="btn-gold !py-2 !text-xs">Εφαρμογή σε όλους</button>
              <span id="bulk-progress" class="text-xs text-text-muted"></span>
            </div>
          </div>
        </div>

        <!-- Tier stats -->
        <div id="tier-stats" class="grid grid-cols-2 gap-3 md:grid-cols-4">
          <!-- filled by JS -->
        </div>

        <!-- Grants table -->
        <div class="rounded-xl border border-border-light bg-white/70 p-6">
          <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <h3 class="text-h3 font-bold text-charcoal">Τρέχουσες πρόσβαση</h3>
            <div class="flex items-center gap-2">
              <input
                id="grants-search"
                type="text"
                placeholder="Αναζήτηση email..."
                class="rounded-lg border border-border-mid bg-cream px-3 py-1.5 text-sm text-charcoal outline-none focus:border-gold"
              />
              <button id="refresh-grants" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">
                Ανανέωση
              </button>
            </div>
          </div>
          <div id="grants-table-wrap" class="overflow-x-auto rounded-lg border border-border-light">
            <table class="w-full min-w-[780px] text-body-sm">
              <thead class="bg-sand text-left text-text-secondary">
                <tr>
                  <th class="px-3 py-2 font-medium">Email</th>
                  <th class="px-3 py-2 font-medium">Πλάνο</th>
                  <th class="px-3 py-2 font-medium">Τύπος</th>
                  <th class="px-3 py-2 font-medium">Status</th>
                  <th class="px-3 py-2 font-medium">Τελ. login</th>
                  <th class="px-3 py-2 font-medium">Λήξη</th>
                  <th class="px-3 py-2 font-medium">Αιτιολογία</th>
                  <th class="px-3 py-2 font-medium text-right">Ενέργειες</th>
                </tr>
              </thead>
              <tbody id="grants-body" class="divide-y divide-border-light">
                <tr><td colspan="8" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- #4: Per-user audit (expandable) -->
        <div id="user-audit-panel" class="hidden rounded-xl border border-gold/30 bg-gold/5 p-6">
          <div class="mb-4 flex items-center justify-between">
            <h3 class="text-h3 font-bold text-charcoal">
              Ιστορικό: <span id="user-audit-email" class="text-gold"></span>
            </h3>
            <button id="close-user-audit" type="button" class="text-xs font-semibold text-text-secondary hover:underline">
              Κλείσιμο
            </button>
          </div>
          <div class="overflow-x-auto rounded-lg border border-border-light">
            <table class="w-full min-w-[500px] text-body-sm">
              <thead class="bg-sand text-left text-text-secondary">
                <tr>
                  <th class="px-3 py-2 font-medium">Ημερομηνία</th>
                  <th class="px-3 py-2 font-medium">Admin</th>
                  <th class="px-3 py-2 font-medium">Ενέργεια</th>
                  <th class="px-3 py-2 font-medium">Λεπτομέρειες</th>
                </tr>
              </thead>
              <tbody id="user-audit-body" class="divide-y divide-border-light">
                <tr><td colspan="4" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Audit log -->
        <div class="rounded-xl border border-border-light bg-white/70 p-6">
          <div class="mb-4 flex items-center justify-between">
            <h3 class="text-h3 font-bold text-charcoal">Ιστορικό αλλαγών</h3>
            <button id="refresh-audit" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">
              Ανανέωση
            </button>
          </div>
          <div class="overflow-x-auto rounded-lg border border-border-light">
            <table class="w-full min-w-[600px] text-body-sm">
              <thead class="bg-sand text-left text-text-secondary">
                <tr>
                  <th class="px-3 py-2 font-medium">Ημερομηνία</th>
                  <th class="px-3 py-2 font-medium">Admin</th>
                  <th class="px-3 py-2 font-medium">Χρήστης</th>
                  <th class="px-3 py-2 font-medium">Ενέργεια</th>
                  <th class="px-3 py-2 font-medium">Λεπτομέρειες</th>
                </tr>
              </thead>
              <tbody id="audit-body" class="divide-y divide-border-light">
                <tr><td colspan="5" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </section>
  </main>
</Base>

<script>
  import { createClient } from "@supabase/supabase-js";

  // --- DOM refs ---
  const status = document.getElementById("status");
  const loginPanel = document.getElementById("login-panel");
  const grantPanel = document.getElementById("grant-panel");
  const loginForm = document.getElementById("login-form");
  const grantForm = document.getElementById("grant-form");
  const adminEmailEl = document.getElementById("admin-email");
  const signOutBtn = document.getElementById("sign-out");
  const grantsBody = document.getElementById("grants-body");
  const auditBody = document.getElementById("audit-body");
  const refreshBtn = document.getElementById("refresh-grants");
  const refreshAuditBtn = document.getElementById("refresh-audit");
  const searchInput = document.getElementById("grants-search");
  const tierStatsEl = document.getElementById("tier-stats");
  const formTitle = document.getElementById("form-title");
  const formResetBtn = document.getElementById("form-reset");
  const templatesBar = document.getElementById("templates-bar");
  const toggleBulkBtn = document.getElementById("toggle-bulk");
  const bulkPanel = document.getElementById("bulk-panel");
  const bulkEmailsEl = document.getElementById("bulk-emails");
  const bulkSubmitBtn = document.getElementById("bulk-submit");
  const bulkProgressEl = document.getElementById("bulk-progress");
  const userAuditPanel = document.getElementById("user-audit-panel");
  const userAuditEmail = document.getElementById("user-audit-email");
  const userAuditBody = document.getElementById("user-audit-body");
  const closeUserAuditBtn = document.getElementById("close-user-audit");

  let supabase;
  let allGrants = [];

  // --- Helpers ---

  function inputValue(id) {
    const el = document.getElementById(id);
    return el instanceof HTMLInputElement ||
      el instanceof HTMLSelectElement ||
      el instanceof HTMLTextAreaElement
      ? el.value.trim()
      : "";
  }

  function setInputValue(id, value) {
    const el = document.getElementById(id);
    if (el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement) {
      el.value = value || "";
    }
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function showStatus(message, kind = "info") {
    if (!status) return;
    const styles = {
      info: "border-border-light bg-white/70 text-text-secondary",
      success: "border-green-700/20 bg-green-50 text-green-900",
      error: "border-red-700/20 bg-red-50 text-red-900",
    };
    status.className = `mb-5 rounded-lg border px-4 py-3 text-body-sm ${styles[kind]}`;
    status.textContent = message;
  }

  function showGrantPanel(email) {
    loginPanel?.classList.add("hidden");
    grantPanel?.classList.remove("hidden");
    if (adminEmailEl) adminEmailEl.textContent = email;
    loadGrants();
    loadAuditLog();
  }

  function showLoginPanel() {
    grantPanel?.classList.add("hidden");
    loginPanel?.classList.remove("hidden");
    if (adminEmailEl) adminEmailEl.textContent = "";
  }

  async function apiCall(path, accessToken, options = {}) {
    const response = await fetch(path, {
      ...options,
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${accessToken}`,
        ...(options.headers || {}),
      },
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data.error || "Request failed");
    return data;
  }

  async function currentAccessToken() {
    const { data } = await supabase.auth.getSession();
    return data.session?.access_token || null;
  }

  // --- Badges & formatters ---

  function tierBadge(tier) {
    const colors = {
      free: "bg-gray-100 text-gray-700",
      solo: "bg-blue-50 text-blue-700",
      pro: "bg-amber-50 text-amber-700",
      team: "bg-purple-50 text-purple-700",
    };
    return `<span class="inline-block rounded-full px-2 py-0.5 text-xs font-semibold ${colors[tier] || ""}">${(tier || "—").toUpperCase()}</span>`;
  }

  function statusBadge(st) {
    const isActive = st === "active";
    return `<span class="inline-block rounded-full px-2 py-0.5 text-xs font-semibold ${isActive ? "bg-green-50 text-green-700" : "bg-red-50 text-red-700"}">${st || "—"}</span>`;
  }

  function formatDate(iso) {
    if (!iso) return "—";
    return new Date(iso).toLocaleDateString("el-GR", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    });
  }

  function formatDateTime(iso) {
    if (!iso) return "—";
    return new Date(iso).toLocaleString("el-GR", {
      day: "2-digit",
      month: "short",
      hour: "2-digit",
      minute: "2-digit",
    });
  }

  // Last login — relative date in Greek
  function formatRelativeLogin(iso) {
    if (!iso) return '<span class="text-text-muted">Ποτέ</span>';
    const diff = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 60) return `Πριν ${mins} λ.`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `Πριν ${hours} ώ.`;
    const days = Math.floor(hours / 24);
    if (days < 30) return `Πριν ${days} ημ.`;
    const months = Math.floor(days / 30);
    return `Πριν ${months} μ.`;
  }

  // #6 — Expiry warning: returns CSS class if expiring within 7 days
  function expiryClass(expiresAt) {
    if (!expiresAt) return "";
    const diff = new Date(expiresAt).getTime() - Date.now();
    if (diff < 0) return "bg-red-50/60";
    if (diff < 7 * 24 * 60 * 60 * 1000) return "bg-amber-50/60";
    return "";
  }

  function expiryLabel(expiresAt) {
    if (!expiresAt) return "—";
    const diff = new Date(expiresAt).getTime() - Date.now();
    const dateStr = formatDate(expiresAt);
    if (diff < 0) return `<span class="font-semibold text-red-700">${dateStr} (ληγμένο)</span>`;
    if (diff < 7 * 24 * 60 * 60 * 1000) {
      const days = Math.ceil(diff / (24 * 60 * 60 * 1000));
      return `<span class="font-semibold text-amber-700">${dateStr} (${days}η)</span>`;
    }
    return dateStr;
  }

  // #5 — Reason: truncate with title tooltip
  function reasonCell(reason) {
    if (!reason) return '<span class="text-text-muted">—</span>';
    const short = reason.length > 25 ? reason.slice(0, 25) + "…" : reason;
    return `<span title="${escapeHtml(reason)}" class="cursor-help text-text-secondary">${escapeHtml(short)}</span>`;
  }

  // --- #4: Tier stats ---
  function renderStats(grants) {
    if (!tierStatsEl) return;
    const counts = { free: 0, solo: 0, pro: 0, team: 0 };
    for (const g of grants) {
      if (counts[g.tier] !== undefined) counts[g.tier]++;
    }
    const total = grants.length;
    const items = [
      { label: "Free", count: counts.free, color: "border-gray-200 bg-gray-50 text-gray-700" },
      { label: "Solo", count: counts.solo, color: "border-blue-200 bg-blue-50 text-blue-700" },
      { label: "Pro", count: counts.pro, color: "border-amber-200 bg-amber-50 text-amber-700" },
      { label: "Team", count: counts.team, color: "border-purple-200 bg-purple-50 text-purple-700" },
    ];
    tierStatsEl.innerHTML = items
      .map(
        (i) => `
      <div class="rounded-lg border ${i.color} px-4 py-3 text-center">
        <p class="text-2xl font-bold">${i.count}</p>
        <p class="text-xs font-semibold">${i.label}</p>
      </div>`,
      )
      .join("");
  }

  // --- #1: Click-to-edit ---
  function fillForm(grant) {
    setInputValue("grant-email", grant.email);
    setInputValue("grant-tier", grant.tier);
    setInputValue("grant-source", grant.source || "manual");
    setInputValue("grant-reason", grant.grant_reason || "");

    // Convert ISO expiry to datetime-local format
    if (grant.expires_at) {
      const d = new Date(grant.expires_at);
      const local = new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
      setInputValue("grant-expires", local);
    } else {
      setInputValue("grant-expires", "");
    }

    if (formTitle) formTitle.textContent = `Επεξεργασία: ${grant.email}`;
    formResetBtn?.classList.remove("hidden");

    // Scroll to form
    grantForm?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function resetForm() {
    grantForm?.reset();
    if (formTitle) formTitle.textContent = "Νέα πρόσβαση";
    formResetBtn?.classList.add("hidden");
  }

  formResetBtn?.addEventListener("click", resetForm);

  // --- #1: Grant templates ---
  const TEMPLATES = {
    "beta30": { tier: "pro", source: "tester", reason: "Beta tester access", daysFromNow: 30 },
    "solo-perm": { tier: "solo", source: "manual", reason: "", daysFromNow: null },
    "pro-perm": { tier: "pro", source: "manual", reason: "", daysFromNow: null },
    "owner": { tier: "team", source: "owner", reason: "Owner access", daysFromNow: null },
  };

  templatesBar?.addEventListener("click", (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const btn = target.closest("[data-tpl]");
    if (!btn) return;
    const tpl = TEMPLATES[btn.getAttribute("data-tpl")];
    if (!tpl) return;

    setInputValue("grant-tier", tpl.tier);
    setInputValue("grant-source", tpl.source);
    setInputValue("grant-reason", tpl.reason);

    if (tpl.daysFromNow) {
      const d = new Date(Date.now() + tpl.daysFromNow * 24 * 60 * 60 * 1000);
      const local = new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
      setInputValue("grant-expires", local);
    } else {
      setInputValue("grant-expires", "");
    }

    if (formTitle) formTitle.textContent = `Νέα πρόσβαση — ${btn.textContent.trim()}`;
    // Focus email field
    document.getElementById("grant-email")?.focus();
  });

  // --- #2 Bulk mode toggle ---
  toggleBulkBtn?.addEventListener("click", () => {
    bulkPanel?.classList.toggle("hidden");
    if (toggleBulkBtn) {
      toggleBulkBtn.textContent = bulkPanel?.classList.contains("hidden") ? "Bulk mode" : "Single mode";
    }
  });

  // --- Bulk submit ---
  bulkSubmitBtn?.addEventListener("click", async () => {
    const raw = bulkEmailsEl instanceof HTMLTextAreaElement ? bulkEmailsEl.value : "";
    const emails = raw.split("\n").map((l) => l.trim().toLowerCase()).filter((l) => l.includes("@"));

    if (emails.length === 0) {
      showStatus("Δεν βρέθηκαν valid emails.", "error");
      return;
    }

    const tier = inputValue("grant-tier");
    const source = inputValue("grant-source");
    const expiresValue = inputValue("grant-expires");
    const expiresAt = expiresValue ? new Date(expiresValue).toISOString() : null;
    const reason = inputValue("grant-reason") || null;

    if (!confirm(`Εφαρμογή ${tier.toUpperCase()} (${source}) σε ${emails.length} χρήστες;`)) return;

    const token = await currentAccessToken();
    if (!token) { showLoginPanel(); return; }

    let ok = 0;
    let fail = 0;
    for (let i = 0; i < emails.length; i++) {
      if (bulkProgressEl) bulkProgressEl.textContent = `${i + 1}/${emails.length}...`;
      try {
        await apiCall("/api/admin/grant-session", token, {
          method: "POST",
          body: JSON.stringify({ email: emails[i], tier, source, expiresAt, reason }),
        });
        ok++;
      } catch {
        fail++;
      }
    }

    if (bulkProgressEl) bulkProgressEl.textContent = "";
    showStatus(`Bulk: ${ok} OK, ${fail} failed (${emails.length} total)`, fail > 0 ? "error" : "success");
    loadGrants();
    loadAuditLog();
  });

  // --- Revoke (downgrade to free) ---
  async function revokeGrant(email) {
    if (!confirm(`Ανάκληση πρόσβασης για ${email}; Θα γίνει downgrade σε Free.`)) return;

    const token = await currentAccessToken();
    if (!token) {
      showLoginPanel();
      return;
    }

    showStatus(`Ανάκληση πρόσβασης ${email}...`);

    try {
      await apiCall("/api/admin/grant-session", token, {
        method: "POST",
        body: JSON.stringify({
          email,
          tier: "free",
          source: "manual",
          expiresAt: null,
          reason: "Revoked by admin",
        }),
      });
      showStatus(`Ανακλήθηκε: ${email} → FREE`, "success");
      loadGrants();
      loadAuditLog();
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Σφάλμα ανάκλησης.", "error");
    }
  }

  // --- Grants table ---

  function renderGrants(grants) {
    if (!grantsBody) return;

    if (!grants || grants.length === 0) {
      grantsBody.innerHTML =
        '<tr><td colspan="8" class="px-3 py-4 text-center text-text-muted">Δεν βρέθηκαν εγγραφές.</td></tr>';
      return;
    }

    grantsBody.innerHTML = grants
      .map(
        (g, i) => `
      <tr class="${expiryClass(g.expires_at)} hover:bg-sand/40 transition-colors">
        <td class="px-3 py-2 font-medium text-charcoal">${escapeHtml(g.email)}</td>
        <td class="px-3 py-2">${tierBadge(escapeHtml(g.tier))}</td>
        <td class="px-3 py-2 text-text-secondary">${escapeHtml(g.source || "—")}</td>
        <td class="px-3 py-2">${statusBadge(escapeHtml(g.status))}</td>
        <td class="px-3 py-2 text-text-muted text-xs">${formatRelativeLogin(g.last_sign_in_at)}</td>
        <td class="px-3 py-2">${expiryLabel(g.expires_at)}</td>
        <td class="px-3 py-2">${reasonCell(g.grant_reason)}</td>
        <td class="px-3 py-2 text-right whitespace-nowrap">
          <button data-action="edit" data-email="${escapeHtml(g.email)}" class="mr-1 rounded px-2 py-1 text-xs font-semibold text-gold hover:bg-gold/10">
            Επεξ/σία
          </button>
          <button data-action="audit" data-email="${escapeHtml(g.email)}" class="mr-1 rounded px-2 py-1 text-xs font-semibold text-text-secondary hover:bg-sand">
            Ιστορικό
          </button>
          ${
            g.tier !== "free"
              ? `<button data-action="revoke" data-email="${escapeHtml(g.email)}" class="rounded px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-50">
                  Ανάκληση
                </button>`
              : ""
          }
        </td>
      </tr>`,
      )
      .join("");
  }

  // Event delegation for table actions
  grantsBody?.addEventListener("click", (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const btn = target.closest("[data-action]");
    if (!btn) return;
    const email = btn.getAttribute("data-email");
    if (!email) return;
    const grant = allGrants.find((g) => g.email === email);

    if (btn.getAttribute("data-action") === "edit" && grant) fillForm(grant);
    if (btn.getAttribute("data-action") === "revoke") revokeGrant(email);
    if (btn.getAttribute("data-action") === "audit") loadUserAudit(email);
  });

  async function loadGrants() {
    if (!grantsBody) return;
    const token = await currentAccessToken();
    if (!token) return;

    grantsBody.innerHTML =
      '<tr><td colspan="8" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>';

    try {
      const grants = await apiCall("/api/admin/list-grants", token);
      allGrants = Array.isArray(grants) ? grants : [];
      renderStats(allGrants);
      filterAndRender();
    } catch {
      grantsBody.innerHTML =
        '<tr><td colspan="8" class="px-3 py-4 text-center text-red-700">Σφάλμα φόρτωσης.</td></tr>';
    }
  }

  // #7 — Search/filter
  function filterAndRender() {
    const query = (searchInput instanceof HTMLInputElement ? searchInput.value : "").toLowerCase().trim();
    const filtered = query
      ? allGrants.filter((g) => g.email?.toLowerCase().includes(query))
      : allGrants;
    renderGrants(filtered);
  }

  searchInput?.addEventListener("input", filterAndRender);

  // --- #3: Audit log ---
  async function loadAuditLog() {
    if (!auditBody) return;
    const token = await currentAccessToken();
    if (!token) return;

    auditBody.innerHTML =
      '<tr><td colspan="5" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>';

    try {
      const entries = await apiCall("/api/admin/audit-log", token);

      if (!Array.isArray(entries) || entries.length === 0) {
        auditBody.innerHTML =
          '<tr><td colspan="5" class="px-3 py-4 text-center text-text-muted">Δεν υπάρχουν εγγραφές.</td></tr>';
        return;
      }

      auditBody.innerHTML = entries
        .map((e) => {
          const p = e.payload || {};
          const detail = [p.tier && String(p.tier).toUpperCase(), p.source].filter(Boolean).join(" / ");
          return `
          <tr class="hover:bg-sand/40">
            <td class="px-3 py-2 text-text-muted">${formatDateTime(e.created_at)}</td>
            <td class="px-3 py-2 text-text-secondary">${escapeHtml(e.admin_email)}</td>
            <td class="px-3 py-2 font-medium text-charcoal">${escapeHtml(e.target_email || "—")}</td>
            <td class="px-3 py-2">${tierBadge(escapeHtml(p.tier || "—"))}</td>
            <td class="px-3 py-2 text-text-secondary">${escapeHtml(detail || "—")}</td>
          </tr>`;
        })
        .join("");
    } catch {
      auditBody.innerHTML =
        '<tr><td colspan="5" class="px-3 py-4 text-center text-red-700">Σφάλμα φόρτωσης.</td></tr>';
    }
  }

  // --- Per-user audit ---
  async function loadUserAudit(email) {
    if (!userAuditPanel || !userAuditBody || !userAuditEmail) return;

    userAuditEmail.textContent = email;
    userAuditPanel.classList.remove("hidden");
    userAuditPanel.scrollIntoView({ behavior: "smooth", block: "start" });

    userAuditBody.innerHTML =
      '<tr><td colspan="4" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>';

    const token = await currentAccessToken();
    if (!token) return;

    try {
      const entries = await apiCall(`/api/admin/audit-log?email=${encodeURIComponent(email)}`, token);

      if (!Array.isArray(entries) || entries.length === 0) {
        userAuditBody.innerHTML =
          '<tr><td colspan="4" class="px-3 py-4 text-center text-text-muted">Δεν υπάρχουν εγγραφές.</td></tr>';
        return;
      }

      userAuditBody.innerHTML = entries
        .map((e) => {
          const p = e.payload || {};
          const detail = [p.tier && String(p.tier).toUpperCase(), p.source, p.expiresAt ? `→ ${formatDate(p.expiresAt)}` : null]
            .filter(Boolean)
            .join(" / ");
          return `
          <tr class="hover:bg-sand/40">
            <td class="px-3 py-2 text-text-muted">${formatDateTime(e.created_at)}</td>
            <td class="px-3 py-2 text-text-secondary">${escapeHtml(e.admin_email)}</td>
            <td class="px-3 py-2">${escapeHtml(e.action || "—")}</td>
            <td class="px-3 py-2 text-text-secondary">${escapeHtml(detail || "—")}</td>
          </tr>`;
        })
        .join("");
    } catch {
      userAuditBody.innerHTML =
        '<tr><td colspan="4" class="px-3 py-4 text-center text-red-700">Σφάλμα φόρτωσης.</td></tr>';
    }
  }

  closeUserAuditBtn?.addEventListener("click", () => {
    userAuditPanel?.classList.add("hidden");
  });

  // --- Auth flow ---

  async function checkAdminSession() {
    const token = await currentAccessToken();
    if (!token) {
      showLoginPanel();
      return;
    }

    try {
      const me = await apiCall("/api/admin/me", token);
      showGrantPanel(me.email);
    } catch {
      await supabase.auth.signOut();
      showLoginPanel();
      showStatus("Δεν υπάρχει admin πρόσβαση για αυτόν τον λογαριασμό.", "error");
    }
  }

  async function init() {
    try {
      const configResponse = await fetch("/api/admin/config");
      const config = await configResponse.json();
      supabase = createClient(config.supabaseUrl, config.supabasePublishableKey);
      await checkAdminSession();
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Δεν φορτώθηκε το admin panel.", "error");
    }
  }

  loginForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    showStatus("Γίνεται σύνδεση...");

    const { error } = await supabase.auth.signInWithPassword({
      email: inputValue("login-email"),
      password: inputValue("login-password"),
    });

    if (error) {
      showStatus("Δεν έγινε σύνδεση. Έλεγξε email/password.", "error");
      return;
    }

    await checkAdminSession();
  });

  grantForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const confirmEmail = inputValue("grant-email");
    const confirmTier = inputValue("grant-tier").toUpperCase();
    const confirmSource = inputValue("grant-source");
    if (
      !confirm(
        `Επιβεβαίωση: Δώσε ${confirmTier} πρόσβαση στον ${confirmEmail} (${confirmSource});`,
      )
    ) {
      return;
    }

    showStatus("Αποθηκεύεται η πρόσβαση...");

    const token = await currentAccessToken();
    if (!token) {
      showLoginPanel();
      showStatus("Η συνεδρία έληξε. Συνδέσου ξανά.", "error");
      return;
    }

    const expiresValue = inputValue("grant-expires");
    const expiresAt = expiresValue ? new Date(expiresValue).toISOString() : null;

    try {
      const result = await apiCall("/api/admin/grant-session", token, {
        method: "POST",
        body: JSON.stringify({
          email: inputValue("grant-email"),
          tier: inputValue("grant-tier"),
          source: inputValue("grant-source"),
          expiresAt,
          reason: inputValue("grant-reason") || null,
        }),
      });

      showStatus(
        `Αποθηκεύτηκε: ${result.email} → ${result.tier} (${result.source})`,
        "success",
      );
      resetForm();
      loadGrants();
      loadAuditLog();
    } catch (err) {
      showStatus(err instanceof Error ? err.message : "Δεν αποθηκεύτηκε η πρόσβαση.", "error");
    }
  });

  refreshBtn?.addEventListener("click", loadGrants);
  refreshAuditBtn?.addEventListener("click", loadAuditLog);

  signOutBtn?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    showLoginPanel();
    showStatus("Έγινε αποσύνδεση.");
  });

  init();
</script>
