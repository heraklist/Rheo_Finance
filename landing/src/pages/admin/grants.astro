---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Rheo Admin - SaaS Management"
  description="Εσωτερική διαχείριση Rheo Finance SaaS."
>
  <main class="min-h-screen bg-cream py-10">
    <section class="section-container max-w-5xl">
      <a href="/" class="mb-8 inline-flex items-center gap-2 text-body-sm font-semibold text-gold">&larr; Πίσω στο Rheo</a>

      <div class="mb-6">
        <div class="mb-3 flex items-center gap-3">
          <img src="/app-icon.png" alt="" class="h-10 w-10 rounded-lg" />
          <div>
            <p class="text-body-sm font-semibold text-gold">Rheo Admin</p>
            <h1 class="text-display-sm font-bold text-charcoal">SaaS Management</h1>
          </div>
        </div>
      </div>

      <!-- Session warning -->
      <div id="session-warning" class="mb-4 hidden rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-body-sm text-amber-900">
        <span>Η session λήγει σύντομα.</span>
        <button id="refresh-session" type="button" class="ml-2 font-semibold text-amber-700 underline">Ανανέωση</button>
      </div>
      <div id="status" class="mb-4 hidden rounded-lg border px-4 py-3 text-body-sm"></div>

      <!-- Login panel -->
      <section id="login-panel" class="rounded-xl border border-border-light bg-white/70 p-6">
        <h2 class="mb-2 text-h2 font-bold text-charcoal">Σύνδεση admin</h2>
        <p class="mb-5 text-body-sm text-text-secondary">Χρησιμοποίησε τον λογαριασμό Supabase που έχει admin πρόσβαση.</p>
        <form id="login-form" class="grid gap-4">
          <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">Email
            <input id="login-email" type="email" required autocomplete="email" class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold" /></label>
          <label class="grid gap-2 text-body-sm font-semibold text-text-secondary">Password
            <input id="login-password" type="password" required autocomplete="current-password" class="rounded-lg border border-border-mid bg-cream px-4 py-3 text-charcoal outline-none focus:border-gold" /></label>
          <button type="submit" class="btn-primary">Σύνδεση</button>
        </form>
      </section>

      <!-- Main panel (after login) -->
      <section id="grant-panel" class="hidden space-y-6">
        <!-- Admin bar -->
        <div class="flex flex-col gap-3 rounded-xl border border-border-light bg-white/70 p-4 md:flex-row md:items-center md:justify-between">
          <div class="flex items-center gap-3">
            <div><p class="text-xs text-text-secondary">Admin</p><p id="admin-email" class="font-semibold text-charcoal text-sm"></p></div>
            <span id="admin-role-badge" class="hidden rounded-full px-2 py-0.5 text-xs font-semibold"></span>
          </div>
          <div class="flex items-center gap-2">
            <label class="flex items-center gap-1.5 text-xs text-text-secondary cursor-pointer"><input id="auto-refresh-toggle" type="checkbox" class="accent-gold" /> Live</label>
            <button id="sign-out" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">Αποσύνδεση</button>
          </div>
        </div>

        <!-- Tab navigation -->
        <div class="flex gap-1 border-b border-border-light" id="tab-nav">
          <button data-tab="users" class="rounded-t-lg border border-b-0 border-gold bg-gold/10 px-4 py-2 text-sm font-semibold text-gold">Χρήστες</button>
          <button data-tab="dashboard" class="rounded-t-lg border border-b-0 border-transparent px-4 py-2 text-sm font-semibold text-text-secondary hover:text-charcoal">Dashboard</button>
          <button data-tab="ops" class="rounded-t-lg border border-b-0 border-transparent px-4 py-2 text-sm font-semibold text-text-secondary hover:text-charcoal">Λειτουργία</button>
          <button data-tab="support" class="rounded-t-lg border border-b-0 border-transparent px-4 py-2 text-sm font-semibold text-text-secondary hover:text-charcoal">Support</button>
        </div>

        <!-- ═══════ TAB: USERS ═══════ -->
        <div id="tab-users" class="space-y-6">
          <!-- Grant form -->
          <div id="write-panel" class="rounded-xl border border-border-light bg-white/70 p-6">
            <div class="mb-4 flex items-center justify-between">
              <h3 class="text-h3 font-bold text-charcoal" id="form-title">Νέα πρόσβαση</h3>
              <div class="flex items-center gap-2">
                <button id="form-reset" type="button" class="hidden text-xs font-semibold text-gold hover:underline">Καθαρισμός</button>
                <button id="toggle-bulk" type="button" class="text-xs font-semibold text-text-secondary hover:text-charcoal hover:underline">Bulk mode</button>
              </div>
            </div>
            <div class="mb-4 flex flex-wrap gap-2" id="templates-bar">
              <button type="button" data-tpl="beta30" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">Beta 30η</button>
              <button type="button" data-tpl="solo-perm" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">Solo perm</button>
              <button type="button" data-tpl="pro-perm" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">Pro perm</button>
              <button type="button" data-tpl="owner" class="rounded-full border border-border-mid bg-sand px-3 py-1 text-xs font-semibold text-text-secondary hover:border-gold hover:text-gold">Owner</button>
            </div>
            <form id="grant-form" class="grid gap-4">
              <label class="grid gap-1.5 text-body-sm font-semibold text-text-secondary">Email χρήστη
                <input id="grant-email" type="email" required autocomplete="off" placeholder="user@example.com" class="rounded-lg border border-border-mid bg-cream px-4 py-2.5 text-charcoal outline-none focus:border-gold" /></label>
              <div id="dup-warning" class="hidden rounded-lg border border-amber-300 bg-amber-50 px-3 py-2 text-xs text-amber-800"></div>
              <div class="grid gap-4 md:grid-cols-2">
                <label class="grid gap-1.5 text-body-sm font-semibold text-text-secondary">Πλάνο
                  <select id="grant-tier" required class="rounded-lg border border-border-mid bg-cream px-4 py-2.5 text-charcoal outline-none focus:border-gold">
                    <option value="free">Free</option><option value="solo">Solo</option><option value="pro">Pro</option><option value="team">Team</option></select></label>
                <label class="grid gap-1.5 text-body-sm font-semibold text-text-secondary">Τύπος
                  <select id="grant-source" required class="rounded-lg border border-border-mid bg-cream px-4 py-2.5 text-charcoal outline-none focus:border-gold">
                    <option value="manual">Manual</option><option value="tester">Tester</option><option value="owner">Owner</option></select></label>
              </div>
              <label class="grid gap-1.5 text-body-sm font-semibold text-text-secondary">Λήξη
                <input id="grant-expires" type="datetime-local" class="rounded-lg border border-border-mid bg-cream px-4 py-2.5 text-charcoal outline-none focus:border-gold" />
                <span class="text-xs font-normal text-text-muted">Κενό = χωρίς λήξη</span></label>
              <label class="grid gap-1.5 text-body-sm font-semibold text-text-secondary">Αιτιολογία
                <textarea id="grant-reason" rows="2" placeholder="π.χ. Beta tester" class="rounded-lg border border-border-mid bg-cream px-4 py-2.5 text-charcoal outline-none focus:border-gold"></textarea></label>
              <label class="flex items-center gap-2 text-body-sm text-text-secondary cursor-pointer"><input id="grant-notify" type="checkbox" class="accent-gold" /> Ειδοποίησε μέσω email</label>
              <button type="submit" class="btn-gold">Αποθήκευση</button>
            </form>
            <div id="bulk-panel" class="mt-5 hidden border-t border-border-light pt-4">
              <h4 class="mb-2 text-body-sm font-semibold text-charcoal">Bulk grant</h4>
              <p class="mb-2 text-xs text-text-muted">Ένα email ανά γραμμή.</p>
              <textarea id="bulk-emails" rows="3" placeholder="user1@example.com&#10;user2@example.com" class="w-full rounded-lg border border-border-mid bg-cream px-4 py-2.5 text-sm text-charcoal outline-none focus:border-gold"></textarea>
              <div class="mt-2 flex items-center gap-3">
                <button id="bulk-submit" type="button" class="btn-gold !py-1.5 !text-xs">Εφαρμογή</button>
                <span id="bulk-progress" class="text-xs text-text-muted"></span>
              </div>
            </div>
          </div>

          <!-- Tier stats + expiring badge -->
          <div class="space-y-3">
            <div id="expiring-badge" class="hidden rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-body-sm font-semibold text-amber-800"></div>
            <div id="tier-stats" class="grid grid-cols-2 gap-3 md:grid-cols-4"></div>
          </div>

          <!-- Activity chart -->
          <div id="activity-chart-wrap" class="hidden rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Δραστηριότητα (8 εβδ.)</h3>
            <div id="activity-chart" class="flex items-end gap-1" style="height:100px;"></div>
          </div>

          <!-- Grants table -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <div class="mb-3 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <h3 class="text-sm font-bold text-charcoal">Πρόσβαση</h3>
              <div class="flex flex-wrap items-center gap-2">
                <input id="grants-search" type="text" placeholder="Αναζήτηση..." class="rounded-lg border border-border-mid bg-cream px-3 py-1.5 text-sm text-charcoal outline-none focus:border-gold w-40" />
                <button id="export-csv" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">CSV</button>
                <button id="batch-extend-btn" type="button" class="hidden btn-secondary !px-3 !py-1.5 text-xs">+30 ημ.</button>
                <button id="refresh-grants" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">Ανανέωση</button>
              </div>
            </div>
            <div class="mb-2 flex flex-wrap gap-1" id="filter-tabs">
              <button data-filter="all" class="rounded-full border border-gold bg-gold/10 px-3 py-1 text-xs font-semibold text-gold">Όλοι</button>
              <button data-filter="active" class="rounded-full border border-border-mid px-3 py-1 text-xs font-semibold text-text-secondary">Active</button>
              <button data-filter="expired" class="rounded-full border border-border-mid px-3 py-1 text-xs font-semibold text-text-secondary">Expired</button>
              <button data-filter="free" class="rounded-full border border-border-mid px-3 py-1 text-xs font-semibold text-text-secondary">Free</button>
            </div>
            <div id="grants-table-wrap" class="overflow-x-auto rounded-lg border border-border-light" style="max-height:500px;">
              <table class="w-full min-w-[900px] text-body-sm">
                <thead class="bg-sand text-left text-text-secondary sticky top-0 z-10">
                  <tr>
                    <th class="w-8 px-2 py-2"><input id="select-all-cb" type="checkbox" class="accent-gold" /></th>
                    <th class="px-3 py-2 font-medium cursor-pointer select-none" data-sort="email">Email <span class="si"></span></th>
                    <th class="px-3 py-2 font-medium cursor-pointer select-none" data-sort="tier">Πλάνο <span class="si"></span></th>
                    <th class="px-3 py-2 font-medium">Τύπος</th>
                    <th class="px-3 py-2 font-medium cursor-pointer select-none" data-sort="status">Status <span class="si"></span></th>
                    <th class="px-3 py-2 font-medium cursor-pointer select-none" data-sort="last_sign_in_at">Τελ. login <span class="si"></span></th>
                    <th class="px-3 py-2 font-medium cursor-pointer select-none" data-sort="user_created_at">Εγγραφή <span class="si"></span></th>
                    <th class="px-3 py-2 font-medium cursor-pointer select-none" data-sort="expires_at">Λήξη <span class="si"></span></th>
                    <th class="px-3 py-2 font-medium">Λόγος</th>
                    <th class="px-3 py-2 font-medium text-right">Ενέργειες</th>
                  </tr>
                </thead>
                <tbody id="grants-body" class="divide-y divide-border-light">
                  <tr><td colspan="10" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Per-user audit -->
          <div id="user-audit-panel" class="hidden rounded-xl border border-gold/30 bg-gold/5 p-5">
            <div class="mb-3 flex items-center justify-between">
              <h3 class="text-sm font-bold text-charcoal">Ιστορικό: <span id="user-audit-email" class="text-gold"></span></h3>
              <button id="close-user-audit" type="button" class="text-xs font-semibold text-text-secondary hover:underline">Κλείσιμο</button>
            </div>
            <div class="mb-3"><div class="mb-2 flex items-center gap-2"><h4 class="text-xs font-semibold text-charcoal">Σημειώσεις</h4><span id="notes-count" class="rounded-full bg-sand px-2 py-0.5 text-xs text-text-muted">0</span></div>
              <div id="user-notes-list" class="mb-2 space-y-1 text-xs"></div>
              <div id="note-form-wrap" class="flex gap-2"><input id="note-input" type="text" placeholder="Νέα σημείωση..." class="flex-1 rounded-lg border border-border-mid bg-cream px-3 py-1.5 text-sm outline-none focus:border-gold" /><button id="add-note-btn" type="button" class="btn-gold !py-1.5 !px-3 !text-xs">+</button></div>
            </div>
            <div class="overflow-x-auto rounded-lg border border-border-light"><table class="w-full min-w-[500px] text-body-sm"><thead class="bg-sand text-left text-text-secondary"><tr><th class="px-3 py-2 font-medium">Ημερομηνία</th><th class="px-3 py-2 font-medium">Admin</th><th class="px-3 py-2 font-medium">Ενέργεια</th><th class="px-3 py-2 font-medium">Λεπτομέρειες</th></tr></thead><tbody id="user-audit-body" class="divide-y divide-border-light"><tr><td colspan="4" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr></tbody></table></div>
          </div>

          <!-- Global audit log -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <div class="mb-3 flex items-center justify-between"><h3 class="text-sm font-bold text-charcoal">Ιστορικό αλλαγών</h3><button id="refresh-audit" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">Ανανέωση</button></div>
            <div class="overflow-x-auto rounded-lg border border-border-light"><table class="w-full min-w-[600px] text-body-sm"><thead class="bg-sand text-left text-text-secondary"><tr><th class="px-3 py-2 font-medium">Ημερομηνία</th><th class="px-3 py-2 font-medium">Admin</th><th class="px-3 py-2 font-medium">Χρήστης</th><th class="px-3 py-2 font-medium">Ενέργεια</th><th class="px-3 py-2 font-medium">Λεπτομέρειες</th></tr></thead><tbody id="audit-body" class="divide-y divide-border-light"><tr><td colspan="5" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr></tbody></table></div>
          </div>
        </div>

        <!-- ═══════ TAB: DASHBOARD ═══════ -->
        <div id="tab-dashboard" class="hidden space-y-6">
          <!-- MRR tiles -->
          <div class="grid grid-cols-2 gap-3 md:grid-cols-4" id="mrr-tiles"></div>

          <!-- Conversion funnel -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Tier Distribution (Funnel)</h3>
            <div id="funnel-chart" class="space-y-2"></div>
          </div>

          <!-- Cohort retention -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Cohort Retention</h3>
            <div id="cohort-grid" class="overflow-x-auto text-xs"></div>
          </div>

          <!-- Churn risk -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Churn Risk</h3>
            <div id="churn-list" class="space-y-1 text-sm"></div>
          </div>
        </div>

        <!-- ═══════ TAB: OPERATIONS ═══════ -->
        <div id="tab-ops" class="hidden space-y-6">
          <!-- System health -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">System Health</h3>
            <div id="health-grid" class="grid grid-cols-2 gap-3 md:grid-cols-4"></div>
          </div>

          <!-- Announcements -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <div class="mb-3 flex items-center justify-between"><h3 class="text-sm font-bold text-charcoal">Announcements</h3><button id="refresh-ann" type="button" class="btn-secondary !px-3 !py-1.5 text-xs">Ανανέωση</button></div>
            <div id="ann-form-wrap" class="mb-4 grid gap-3 rounded-lg border border-border-light bg-sand/30 p-4">
              <div class="grid gap-3 md:grid-cols-2">
                <input id="ann-title" type="text" placeholder="Τίτλος" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold" />
                <select id="ann-type" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold">
                  <option value="info">Info</option><option value="warning">Warning</option><option value="maintenance">Maintenance</option></select>
              </div>
              <textarea id="ann-message" rows="2" placeholder="Μήνυμα..." class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold"></textarea>
              <button id="ann-create" type="button" class="btn-gold !py-1.5 !text-xs w-fit">Δημιουργία</button>
            </div>
            <div id="ann-list" class="space-y-2"></div>
          </div>

          <!-- Feature flags -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <div class="mb-3 flex items-center justify-between"><h3 class="text-sm font-bold text-charcoal">Feature Flags</h3></div>
            <div id="flags-form" class="mb-4 flex flex-wrap gap-2 items-end rounded-lg border border-border-light bg-sand/30 p-4">
              <input id="flag-key" type="text" placeholder="flag_key" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold w-40" />
              <input id="flag-desc" type="text" placeholder="Περιγραφή" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold flex-1" />
              <button id="flag-create" type="button" class="btn-gold !py-2 !text-xs">Προσθήκη</button>
            </div>
            <div id="flags-list" class="space-y-2"></div>
          </div>

          <!-- Trial management -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Trial Management</h3>
            <p class="mb-2 text-xs text-text-muted">Χρήστες με ενεργή πρόσβαση που λήγει σύντομα ή έχει λήξει.</p>
            <div id="trial-list" class="space-y-1 text-sm"></div>
          </div>
        </div>

        <!-- ═══════ TAB: SUPPORT ═══════ -->
        <div id="tab-support" class="hidden space-y-6">
          <!-- Support tickets -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <div class="mb-3 flex items-center justify-between"><h3 class="text-sm font-bold text-charcoal">Support Tickets</h3></div>
            <div id="ticket-form" class="mb-4 grid gap-3 rounded-lg border border-border-light bg-sand/30 p-4 md:grid-cols-3">
              <input id="ticket-email" type="email" placeholder="Email χρήστη" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold" />
              <input id="ticket-subject" type="text" placeholder="Θέμα" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold" />
              <div class="flex gap-2">
                <select id="ticket-priority" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold flex-1">
                  <option value="low">Low</option><option value="normal" selected>Normal</option><option value="high">High</option></select>
                <button id="ticket-create" type="button" class="btn-gold !py-2 !text-xs whitespace-nowrap">Δημιουργία</button>
              </div>
            </div>
            <div id="ticket-list" class="space-y-2"></div>
          </div>

          <!-- Impersonate view -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Impersonate View</h3>
            <div class="flex gap-2 mb-3">
              <input id="impersonate-email" type="email" placeholder="Email χρήστη" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold flex-1" />
              <button id="impersonate-btn" type="button" class="btn-secondary !px-3 !py-2 !text-xs">Δες σαν χρήστης</button>
            </div>
            <div id="impersonate-result" class="hidden rounded-lg border border-border-light bg-sand/30 p-4 text-sm"></div>
          </div>

          <!-- GDPR export -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">GDPR Data Export</h3>
            <div class="flex gap-2">
              <input id="gdpr-email" type="email" placeholder="Email χρήστη" class="rounded-lg border border-border-mid bg-cream px-3 py-2 text-sm outline-none focus:border-gold flex-1" />
              <button id="gdpr-btn" type="button" class="btn-secondary !px-3 !py-2 !text-xs">Export JSON</button>
            </div>
          </div>

          <!-- Login anomaly -->
          <div class="rounded-xl border border-border-light bg-white/70 p-5">
            <h3 class="mb-3 text-sm font-bold text-charcoal">Login Anomalies</h3>
            <p class="mb-2 text-xs text-text-muted">Χρήστες με ασυνήθιστα login patterns.</p>
            <div id="anomaly-list" class="space-y-1 text-sm"></div>
          </div>
        </div>

      </section>
    </section>
  </main>
</Base>

<script>
  import { createClient } from "@supabase/supabase-js";

  const $ = (id) => document.getElementById(id);
  const TIER_PRICE = { free: 0, solo: 4.99, pro: 9.99, team: 19.99 };
  const COL = 10;

  let supabase, allGrants = [], allAuditEntries = [], adminRole = "admin";
  let currentSort = { key: "", dir: "asc" }, currentFilter = "all", selectedEmails = new Set();
  let autoRefreshInterval = null, sessionCheckInterval = null, currentAuditEmail = "";
  let tabLoaded = { users: false, dashboard: false, ops: false, support: false };

  // ── Helpers ──
  function iv(id) { const el = $(id); return el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement ? el.value.trim() : ""; }
  function sv(id, v) { const el = $(id); if (el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement) el.value = v || ""; }
  function esc(v) { return String(v ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }

  function showStatus(msg, kind = "info") {
    const s = $("status"); if (!s) return;
    const st = { info: "border-border-light bg-white/70 text-text-secondary", success: "border-green-700/20 bg-green-50 text-green-900", error: "border-red-700/20 bg-red-50 text-red-900" };
    s.className = `mb-4 rounded-lg border px-4 py-3 text-body-sm ${st[kind]}`; s.textContent = msg;
  }

  async function api(path, token, opts = {}) {
    const r = await fetch(path, { ...opts, headers: { "Content-Type": "application/json", Authorization: `Bearer ${token}`, ...(opts.headers || {}) } });
    const d = await r.json().catch(() => ({})); if (!r.ok) throw new Error(d.error || "Request failed"); return d;
  }

  async function tok() { const { data } = await supabase.auth.getSession(); return data.session?.access_token || null; }

  function tierBadge(t) { const c = { free: "bg-gray-100 text-gray-700", solo: "bg-blue-50 text-blue-700", pro: "bg-amber-50 text-amber-700", team: "bg-purple-50 text-purple-700" }; return `<span class="inline-block rounded-full px-2 py-0.5 text-xs font-semibold ${c[t] || ""}">${(t || "—").toUpperCase()}</span>`; }
  function statusBadge(s) { return `<span class="inline-block rounded-full px-2 py-0.5 text-xs font-semibold ${s === "active" ? "bg-green-50 text-green-700" : "bg-red-50 text-red-700"}">${s || "—"}</span>`; }
  function fmtD(iso) { return iso ? new Date(iso).toLocaleDateString("el-GR", { day: "2-digit", month: "short", year: "numeric" }) : "—"; }
  function fmtDT(iso) { return iso ? new Date(iso).toLocaleString("el-GR", { day: "2-digit", month: "short", hour: "2-digit", minute: "2-digit" }) : "—"; }
  function relLogin(iso) { if (!iso) return '<span class="text-text-muted">Ποτέ</span>'; const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000); if (m < 1) return "Τώρα"; if (m < 60) return `${m}λ`; const h = Math.floor(m / 60); if (h < 24) return `${h}ώ`; const d = Math.floor(h / 24); return d < 30 ? `${d}η` : `${Math.floor(d / 30)}μ`; }
  function expCls(e) { if (!e) return ""; const d = new Date(e).getTime() - Date.now(); return d < 0 ? "bg-red-50/60" : d < 7*864e5 ? "bg-amber-50/60" : ""; }
  function expLbl(e) { if (!e) return "—"; const d = new Date(e).getTime() - Date.now(), ds = fmtD(e); return d < 0 ? `<span class="font-semibold text-red-700">${ds} !</span>` : d < 7*864e5 ? `<span class="font-semibold text-amber-700">${ds} (${Math.ceil(d/864e5)}η)</span>` : ds; }
  function reasonC(r) { if (!r) return "—"; const s = r.length > 18 ? r.slice(0, 18) + "…" : r; return `<span title="${esc(r)}" class="cursor-help text-text-secondary">${esc(s)}</span>`; }

  // ── Tab navigation ──
  $("tab-nav")?.addEventListener("click", (e) => {
    const btn = e.target instanceof Element ? e.target.closest("[data-tab]") : null;
    if (!btn) return;
    const tab = btn.getAttribute("data-tab");
    document.querySelectorAll("[data-tab]").forEach((b) => { b.className = b === btn ? "rounded-t-lg border border-b-0 border-gold bg-gold/10 px-4 py-2 text-sm font-semibold text-gold" : "rounded-t-lg border border-b-0 border-transparent px-4 py-2 text-sm font-semibold text-text-secondary hover:text-charcoal"; });
    ["users", "dashboard", "ops", "support"].forEach((t) => { const el = $(`tab-${t}`); if (el) el.classList.toggle("hidden", t !== tab); });
    if (tab && !tabLoaded[tab]) { tabLoaded[tab] = true; loadTab(tab); }
  });

  async function loadTab(tab) {
    const t = await tok(); if (!t) return;
    if (tab === "dashboard") renderDashboard();
    if (tab === "ops") loadOps(t);
    if (tab === "support") loadSupport(t);
  }

  // ══════════════════════════════════════════════════════
  // TAB: USERS (existing features — unchanged logic)
  // ══════════════════════════════════════════════════════

  function showGrantPanel(email, role) {
    adminRole = role || "admin";
    $("login-panel")?.classList.add("hidden"); $("grant-panel")?.classList.remove("hidden");
    if ($("admin-email")) $("admin-email").textContent = email;
    const rb = $("admin-role-badge");
    if (rb) { rb.classList.remove("hidden"); rb.textContent = adminRole === "viewer" ? "Viewer" : "Admin"; rb.className = `rounded-full px-2 py-0.5 text-xs font-semibold ${adminRole === "viewer" ? "bg-gray-100 text-gray-600" : "bg-gold/10 text-gold"}`; }
    if (adminRole === "viewer") $("write-panel")?.classList.add("hidden"); else $("write-panel")?.classList.remove("hidden");
    tabLoaded.users = true;
    loadGrants(); loadAuditLog(); startSessionCheck();
  }

  function showLoginPanel() { $("grant-panel")?.classList.add("hidden"); $("login-panel")?.classList.remove("hidden"); stopAutoRefresh(); stopSessionCheck(); }

  // Stats + expiring badge
  function renderStats(grants) {
    const el = $("tier-stats"); if (!el) return;
    const c = { free: 0, solo: 0, pro: 0, team: 0 }; let exp7 = 0;
    for (const g of grants) { if (c[g.tier] !== undefined) c[g.tier]++; if (g.expires_at) { const d = new Date(g.expires_at).getTime() - Date.now(); if (d > 0 && d < 7*864e5) exp7++; } }
    el.innerHTML = [{ l: "Free", n: c.free, cl: "border-gray-200 bg-gray-50 text-gray-700" }, { l: "Solo", n: c.solo, cl: "border-blue-200 bg-blue-50 text-blue-700" }, { l: "Pro", n: c.pro, cl: "border-amber-200 bg-amber-50 text-amber-700" }, { l: "Team", n: c.team, cl: "border-purple-200 bg-purple-50 text-purple-700" }].map((i) => `<div class="rounded-lg border ${i.cl} px-4 py-3 text-center"><p class="text-2xl font-bold">${i.n}</p><p class="text-xs font-semibold">${i.l}</p></div>`).join("");
    const eb = $("expiring-badge"); if (eb) { if (exp7 > 0) { eb.textContent = `${exp7} λήγουν σε 7 ημέρες`; eb.classList.remove("hidden"); } else eb.classList.add("hidden"); }
  }

  // Activity chart
  function renderActivityChart(entries) {
    const ch = $("activity-chart"), cw = $("activity-chart-wrap"); if (!ch || !cw) return;
    if (!entries.length) { cw.classList.add("hidden"); return; }
    const wks = {}; const now = Date.now();
    for (let i = 7; i >= 0; i--) { const d = new Date(now - i*7*864e5); const k = `${d.getMonth()+1}/${d.getDate()}`; wks[k] = { g: 0, r: 0 }; }
    const keys = Object.keys(wks);
    for (const e of entries) { const d = new Date(e.created_at); const k = `${d.getMonth()+1}/${d.getDate()}`; const closest = keys.reduce((a, b) => Math.abs(new Date(`2026/${b}`).getTime() - d.getTime()) < Math.abs(new Date(`2026/${a}`).getTime() - d.getTime()) ? b : a); if (wks[closest]) { e.payload?.tier === "free" ? wks[closest].r++ : wks[closest].g++; } }
    const mx = Math.max(1, ...Object.values(wks).map((w) => w.g + w.r));
    ch.innerHTML = keys.map((k) => { const w = wks[k]; return `<div class="flex-1 flex flex-col items-center gap-0.5" title="${k}: ${w.g}g ${w.r}r"><div class="w-full flex flex-col justify-end" style="height:80px;"><div class="w-full rounded-t bg-green-400" style="height:${Math.round(w.g/mx*70)}px;"></div><div class="w-full rounded-b bg-red-300" style="height:${Math.round(w.r/mx*70)}px;"></div></div><span class="text-[9px] text-text-muted">${k}</span></div>`; }).join("");
    cw.classList.remove("hidden");
  }

  // Grant form
  const TPLS = { beta30: { t: "pro", s: "tester", r: "Beta tester", d: 30 }, "solo-perm": { t: "solo", s: "manual", r: "", d: null }, "pro-perm": { t: "pro", s: "manual", r: "", d: null }, owner: { t: "team", s: "owner", r: "Owner", d: null } };
  function fillForm(g) { if (adminRole === "viewer") return; sv("grant-email", g.email); sv("grant-tier", g.tier); sv("grant-source", g.source || "manual"); sv("grant-reason", g.grant_reason || ""); if (g.expires_at) { const d = new Date(g.expires_at); sv("grant-expires", new Date(d.getTime() - d.getTimezoneOffset()*6e4).toISOString().slice(0, 16)); } else sv("grant-expires", ""); if ($("form-title")) $("form-title").textContent = `Επεξεργασία: ${g.email}`; $("form-reset")?.classList.remove("hidden"); $("grant-form")?.scrollIntoView({ behavior: "smooth" }); }
  function resetForm() { $("grant-form")?.reset(); if ($("form-title")) $("form-title").textContent = "Νέα πρόσβαση"; $("form-reset")?.classList.add("hidden"); $("dup-warning")?.classList.add("hidden"); }
  $("form-reset")?.addEventListener("click", resetForm);
  $("templates-bar")?.addEventListener("click", (e) => { const t = e.target instanceof Element ? e.target.closest("[data-tpl]") : null; if (!t) return; const tp = TPLS[t.getAttribute("data-tpl")]; if (!tp) return; sv("grant-tier", tp.t); sv("grant-source", tp.s); sv("grant-reason", tp.r); if (tp.d) { const d = new Date(Date.now() + tp.d*864e5); sv("grant-expires", new Date(d.getTime() - d.getTimezoneOffset()*6e4).toISOString().slice(0, 16)); } else sv("grant-expires", ""); $("grant-email")?.focus(); });

  // Duplicate detection
  function chkDup() { const em = iv("grant-email").toLowerCase(), ti = iv("grant-tier"), dw = $("dup-warning"); if (!em || !dw) return; const ex = allGrants.find((g) => g.email?.toLowerCase() === em); if (ex && ex.tier === ti) { dw.textContent = `${em} έχει ήδη ${ti.toUpperCase()}.`; dw.classList.remove("hidden"); } else if (ex) { dw.textContent = `${em}: ${(ex.tier||"").toUpperCase()} → ${ti.toUpperCase()}`; dw.classList.remove("hidden"); } else dw.classList.add("hidden"); }
  $("grant-email")?.addEventListener("input", chkDup); $("grant-tier")?.addEventListener("change", chkDup);

  // Bulk
  $("toggle-bulk")?.addEventListener("click", () => { $("bulk-panel")?.classList.toggle("hidden"); if ($("toggle-bulk")) $("toggle-bulk").textContent = $("bulk-panel")?.classList.contains("hidden") ? "Bulk mode" : "Single mode"; });
  $("bulk-submit")?.addEventListener("click", async () => {
    const raw = $("bulk-emails") instanceof HTMLTextAreaElement ? $("bulk-emails").value : "";
    const emails = raw.split("\n").map((l) => l.trim().toLowerCase()).filter((l) => l.includes("@"));
    if (!emails.length) { showStatus("Δεν βρέθηκαν emails.", "error"); return; }
    const tier = iv("grant-tier"), source = iv("grant-source"), ev = iv("grant-expires"), ea = ev ? new Date(ev).toISOString() : null, reason = iv("grant-reason") || null;
    if (!confirm(`${tier.toUpperCase()} σε ${emails.length} χρήστες;`)) return;
    const t = await tok(); if (!t) { showLoginPanel(); return; }
    let ok = 0, fail = 0;
    for (let i = 0; i < emails.length; i++) { if ($("bulk-progress")) $("bulk-progress").textContent = `${i+1}/${emails.length}`; try { await api("/api/admin/grant-session", t, { method: "POST", body: JSON.stringify({ email: emails[i], tier, source, expiresAt: ea, reason }) }); ok++; } catch { fail++; } }
    if ($("bulk-progress")) $("bulk-progress").textContent = ""; showStatus(`Bulk: ${ok} OK, ${fail} fail`, fail ? "error" : "success"); loadGrants(); loadAuditLog();
  });

  // Revoke
  async function revokeGrant(email) { if (!confirm(`Ανάκληση ${email} → Free;`)) return; const t = await tok(); if (!t) return; try { await api("/api/admin/grant-session", t, { method: "POST", body: JSON.stringify({ email, tier: "free", source: "manual", expiresAt: null, reason: "Revoked" }) }); showStatus(`${email} → FREE`, "success"); loadGrants(); loadAuditLog(); } catch (e) { showStatus(e.message, "error"); } }

  // Batch extend + select
  function updateBatchBtn() { const b = $("batch-extend-btn"); if (b) { if (selectedEmails.size && adminRole === "admin") { b.classList.remove("hidden"); b.textContent = `+30η (${selectedEmails.size})`; } else b.classList.add("hidden"); } }
  $("select-all-cb")?.addEventListener("change", () => { const ch = $("select-all-cb") instanceof HTMLInputElement && $("select-all-cb").checked; selectedEmails.clear(); if (ch) getFiltered().forEach((g) => selectedEmails.add(g.email)); document.querySelectorAll(".rcb").forEach((c) => { if (c instanceof HTMLInputElement) c.checked = ch; }); updateBatchBtn(); });
  $("batch-extend-btn")?.addEventListener("click", async () => {
    if (!selectedEmails.size || !confirm(`+30η για ${selectedEmails.size};`)) return;
    const t = await tok(); if (!t) return; let ok = 0, fail = 0;
    for (const em of selectedEmails) { const g = allGrants.find((x) => x.email === em); if (!g) { fail++; continue; } const base = g.expires_at ? new Date(g.expires_at) : new Date(); try { await api("/api/admin/grant-session", t, { method: "POST", body: JSON.stringify({ email: em, tier: g.tier, source: g.source || "manual", expiresAt: new Date(base.getTime()+30*864e5).toISOString(), reason: "+30 days" }) }); ok++; } catch { fail++; } }
    selectedEmails.clear(); updateBatchBtn(); showStatus(`+30η: ${ok} OK, ${fail} fail`, fail ? "error" : "success"); loadGrants(); loadAuditLog();
  });

  // Sorting
  function sortArr(arr, k, d) { return [...arr].sort((a, b) => { let va = a[k] ?? "", vb = b[k] ?? ""; if (typeof va === "string") va = va.toLowerCase(); if (typeof vb === "string") vb = vb.toLowerCase(); return va < vb ? (d === "asc" ? -1 : 1) : va > vb ? (d === "asc" ? 1 : -1) : 0; }); }
  document.querySelectorAll("[data-sort]").forEach((th) => th.addEventListener("click", () => { const k = th.getAttribute("data-sort"); currentSort = currentSort.key === k ? { key: k, dir: currentSort.dir === "asc" ? "desc" : "asc" } : { key: k, dir: "asc" }; document.querySelectorAll(".si").forEach((s) => { s.textContent = ""; }); const ic = th.querySelector(".si"); if (ic) ic.textContent = currentSort.dir === "asc" ? " ↑" : " ↓"; filterAndRender(); }));

  // Filter tabs
  $("filter-tabs")?.addEventListener("click", (e) => { const btn = e.target instanceof Element ? e.target.closest("[data-filter]") : null; if (!btn) return; currentFilter = btn.getAttribute("data-filter") || "all"; $("filter-tabs").querySelectorAll("button").forEach((b) => { b.className = b === btn ? "rounded-full border border-gold bg-gold/10 px-3 py-1 text-xs font-semibold text-gold" : "rounded-full border border-border-mid px-3 py-1 text-xs font-semibold text-text-secondary"; }); filterAndRender(); });

  function getFiltered() {
    const q = ($("grants-search") instanceof HTMLInputElement ? $("grants-search").value : "").toLowerCase().trim();
    let f = allGrants; if (q) f = f.filter((g) => g.email?.toLowerCase().includes(q));
    if (currentFilter === "active") f = f.filter((g) => g.status === "active");
    else if (currentFilter === "expired") f = f.filter((g) => g.expires_at && new Date(g.expires_at).getTime() < Date.now());
    else if (currentFilter === "free") f = f.filter((g) => g.tier === "free");
    if (currentSort.key) f = sortArr(f, currentSort.key, currentSort.dir);
    return f;
  }

  function renderGrants(grants) {
    const gb = $("grants-body"); if (!gb) return;
    if (!grants.length) { gb.innerHTML = `<tr><td colspan="${COL}" class="px-3 py-4 text-center text-text-muted">Δεν βρέθηκαν.</td></tr>`; return; }
    const isA = adminRole === "admin";
    gb.innerHTML = grants.map((g) => `<tr class="${expCls(g.expires_at)} hover:bg-sand/40"><td class="px-2 py-2">${isA ? `<input type="checkbox" class="rcb accent-gold" data-email="${esc(g.email)}" ${selectedEmails.has(g.email) ? "checked" : ""} />` : ""}</td><td class="px-3 py-2 font-medium"><span class="cursor-pointer hover:text-gold" data-action="copy" data-email="${esc(g.email)}" title="Copy">${esc(g.email)}</span></td><td class="px-3 py-2">${tierBadge(g.tier)}</td><td class="px-3 py-2 text-text-secondary text-xs">${esc(g.source||"—")}</td><td class="px-3 py-2">${statusBadge(g.status)}</td><td class="px-3 py-2 text-text-muted text-xs" title="${g.last_sign_in_at ? fmtDT(g.last_sign_in_at) : ""}">${relLogin(g.last_sign_in_at)}</td><td class="px-3 py-2 text-text-muted text-xs">${fmtD(g.user_created_at)}</td><td class="px-3 py-2">${expLbl(g.expires_at)}</td><td class="px-3 py-2">${reasonC(g.grant_reason)}</td><td class="px-3 py-2 text-right whitespace-nowrap">${isA ? `<button data-action="edit" data-email="${esc(g.email)}" class="mr-1 rounded px-2 py-1 text-xs font-semibold text-gold hover:bg-gold/10">Επεξ</button>` : ""}<button data-action="audit" data-email="${esc(g.email)}" class="mr-1 rounded px-2 py-1 text-xs font-semibold text-text-secondary hover:bg-sand">Ιστ</button>${isA && g.tier !== "free" ? `<button data-action="revoke" data-email="${esc(g.email)}" class="rounded px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-50">Rev</button>` : ""}</td></tr>`).join("");
  }

  function filterAndRender() { renderGrants(getFiltered()); }
  $("grants-search")?.addEventListener("input", filterAndRender);

  // Table click delegation
  $("grants-body")?.addEventListener("click", (e) => {
    const t = e.target; if (!(t instanceof Element)) return;
    if (t.classList.contains("rcb") && t instanceof HTMLInputElement) { const em = t.getAttribute("data-email"); if (em) { t.checked ? selectedEmails.add(em) : selectedEmails.delete(em); } updateBatchBtn(); return; }
    const cp = t.closest("[data-action='copy']"); if (cp) { const em = cp.getAttribute("data-email"); if (em) navigator.clipboard.writeText(em).then(() => { cp.textContent = "OK!"; setTimeout(() => { cp.textContent = em; }, 800); }); return; }
    const btn = t.closest("[data-action]"); if (!btn) return; const em = btn.getAttribute("data-email"); if (!em) return; const a = btn.getAttribute("data-action"), g = allGrants.find((x) => x.email === em);
    if (a === "edit" && g) fillForm(g); if (a === "revoke") revokeGrant(em); if (a === "audit") loadUserAudit(em);
  });

  async function loadGrants() {
    const gb = $("grants-body"); if (!gb) return; const t = await tok(); if (!t) return;
    gb.innerHTML = `<tr><td colspan="${COL}" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>`;
    try { const g = await api("/api/admin/list-grants", t); allGrants = Array.isArray(g) ? g : []; renderStats(allGrants); filterAndRender(); } catch { gb.innerHTML = `<tr><td colspan="${COL}" class="px-3 py-4 text-center text-red-700">Σφάλμα.</td></tr>`; }
  }

  // CSV
  $("export-csv")?.addEventListener("click", () => {
    if (!allGrants.length) return; const h = ["Email","Tier","Source","Status","LastLogin","Created","Expires","Reason"];
    const rows = allGrants.map((g) => [g.email, g.tier, g.source, g.status, g.last_sign_in_at||"", g.user_created_at||"", g.expires_at||"", g.grant_reason||""].map((v) => `"${String(v).replace(/"/g,'""')}"`).join(","));
    const blob = new Blob(["﻿" + [h.join(","), ...rows].join("\n")], { type: "text/csv;charset=utf-8;" });
    const a = document.createElement("a"); a.href = URL.createObjectURL(blob); a.download = `rheo-grants-${new Date().toISOString().slice(0,10)}.csv`; a.click();
  });

  // Audit log
  async function loadAuditLog() {
    const ab = $("audit-body"); if (!ab) return; const t = await tok(); if (!t) return;
    ab.innerHTML = '<tr><td colspan="5" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>';
    try { const entries = await api("/api/admin/audit-log", t); allAuditEntries = Array.isArray(entries) ? entries : [];
      if (!allAuditEntries.length) { ab.innerHTML = '<tr><td colspan="5" class="px-3 py-4 text-center text-text-muted">Κενό.</td></tr>'; }
      else ab.innerHTML = allAuditEntries.map((e) => { const p = e.payload||{}; const d = [p.tier&&String(p.tier).toUpperCase(), p.source].filter(Boolean).join("/"); return `<tr class="hover:bg-sand/40"><td class="px-3 py-2 text-text-muted">${fmtDT(e.created_at)}</td><td class="px-3 py-2 text-text-secondary">${esc(e.admin_email)}</td><td class="px-3 py-2 font-medium">${esc(e.target_email||"—")}</td><td class="px-3 py-2">${tierBadge(p.tier||"—")}</td><td class="px-3 py-2 text-text-secondary">${esc(d||"—")}</td></tr>`; }).join("");
      renderActivityChart(allAuditEntries);
    } catch { ab.innerHTML = '<tr><td colspan="5" class="px-3 py-4 text-center text-red-700">Σφάλμα.</td></tr>'; }
  }

  // Per-user audit + notes
  async function loadUserAudit(email) {
    const p = $("user-audit-panel"), b = $("user-audit-body"), e = $("user-audit-email"); if (!p||!b||!e) return;
    currentAuditEmail = email; e.textContent = email; p.classList.remove("hidden"); p.scrollIntoView({ behavior: "smooth" });
    if ($("note-form-wrap")) $("note-form-wrap").style.display = adminRole === "admin" ? "" : "none";
    b.innerHTML = '<tr><td colspan="4" class="px-3 py-4 text-center text-text-muted">Φόρτωση...</td></tr>';
    const t = await tok(); if (!t) return;
    const [aR, nR] = await Promise.allSettled([api(`/api/admin/audit-log?email=${encodeURIComponent(email)}`, t), api(`/api/admin/audit-log?type=notes&email=${encodeURIComponent(email)}`, t)]);
    const entries = aR.status === "fulfilled" && Array.isArray(aR.value) ? aR.value : [];
    b.innerHTML = entries.length ? entries.map((e) => { const p = e.payload||{}; const d = [p.tier&&String(p.tier).toUpperCase(), p.source].filter(Boolean).join("/"); return `<tr class="hover:bg-sand/40"><td class="px-3 py-2 text-text-muted">${fmtDT(e.created_at)}</td><td class="px-3 py-2 text-text-secondary">${esc(e.admin_email)}</td><td class="px-3 py-2">${esc(e.action||"—")}</td><td class="px-3 py-2 text-text-secondary">${esc(d||"—")}</td></tr>`; }).join("") : '<tr><td colspan="4" class="px-3 py-4 text-center text-text-muted">Κενό.</td></tr>';
    renderNotes(nR.status === "fulfilled" && Array.isArray(nR.value) ? nR.value : []);
  }
  function renderNotes(notes) { const nl = $("user-notes-list"), nc = $("notes-count"); if (!nl||!nc) return; nc.textContent = String(notes.length); nl.innerHTML = notes.length ? notes.map((n) => `<div class="rounded border border-border-light bg-white/60 px-3 py-1.5"><p class="text-text-secondary">${esc(n.note)}</p><p class="mt-0.5 text-text-muted" style="font-size:10px;">${esc(n.admin_email)} — ${fmtDT(n.created_at)}</p></div>`).join("") : '<p class="text-text-muted">Κενό.</p>'; }
  $("add-note-btn")?.addEventListener("click", async () => { const n = $("note-input") instanceof HTMLInputElement ? $("note-input").value.trim() : ""; if (!n||!currentAuditEmail) return; const t = await tok(); if (!t) return; try { await api("/api/admin/audit-log", t, { method: "POST", body: JSON.stringify({ email: currentAuditEmail, note: n }) }); if ($("note-input") instanceof HTMLInputElement) $("note-input").value = ""; const notes = await api(`/api/admin/audit-log?type=notes&email=${encodeURIComponent(currentAuditEmail)}`, t); renderNotes(Array.isArray(notes) ? notes : []); } catch (e) { showStatus(e.message, "error"); } });
  $("close-user-audit")?.addEventListener("click", () => { $("user-audit-panel")?.classList.add("hidden"); currentAuditEmail = ""; });

  // ══════════════════════════════════════════════════════
  // TAB: DASHBOARD (#1 MRR, #2 Funnel, #3 Cohort, #5 Churn)
  // ══════════════════════════════════════════════════════

  function renderDashboard() {
    // #1 MRR/ARR
    const mt = $("mrr-tiles"); if (mt) {
      let mrr = 0, paid = 0; for (const g of allGrants) { if (g.status === "active" && g.tier !== "free") { mrr += TIER_PRICE[g.tier] || 0; paid++; } }
      mt.innerHTML = [
        { l: "MRR", v: `€${mrr.toFixed(2)}`, cl: "border-green-200 bg-green-50 text-green-700" },
        { l: "ARR", v: `€${(mrr*12).toFixed(0)}`, cl: "border-green-200 bg-green-50 text-green-700" },
        { l: "Paid Users", v: paid, cl: "border-blue-200 bg-blue-50 text-blue-700" },
        { l: "Total Users", v: allGrants.length, cl: "border-gray-200 bg-gray-50 text-gray-700" },
      ].map((i) => `<div class="rounded-lg border ${i.cl} px-4 py-3 text-center"><p class="text-2xl font-bold">${i.v}</p><p class="text-xs font-semibold">${i.l}</p></div>`).join("");
    }

    // #2 Funnel
    const fc = $("funnel-chart"); if (fc) {
      const c = { free: 0, solo: 0, pro: 0, team: 0 }; for (const g of allGrants) { if (c[g.tier] !== undefined) c[g.tier]++; }
      const tot = allGrants.length || 1;
      const tiers = [{ k: "free", l: "Free", cl: "bg-gray-300" }, { k: "solo", l: "Solo", cl: "bg-blue-400" }, { k: "pro", l: "Pro", cl: "bg-amber-400" }, { k: "team", l: "Team", cl: "bg-purple-400" }];
      fc.innerHTML = tiers.map((t) => { const pct = Math.round(c[t.k]/tot*100); return `<div class="flex items-center gap-3"><span class="w-12 text-right text-xs font-semibold text-text-secondary">${t.l}</span><div class="flex-1 rounded-full bg-sand h-6 overflow-hidden"><div class="${t.cl} h-full rounded-full flex items-center px-2" style="width:${Math.max(pct,4)}%;"><span class="text-xs font-bold text-white">${c[t.k]} (${pct}%)</span></div></div></div>`; }).join("");
    }

    // #3 Cohort retention
    const cg = $("cohort-grid"); if (cg) {
      const months = {}; const now = new Date();
      for (const g of allGrants) {
        if (!g.user_created_at) continue;
        const d = new Date(g.user_created_at);
        const mk = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`;
        if (!months[mk]) months[mk] = { total: 0, active30: 0, active7: 0 };
        months[mk].total++;
        if (g.last_sign_in_at) {
          const diff = now.getTime() - new Date(g.last_sign_in_at).getTime();
          if (diff < 30*864e5) months[mk].active30++;
          if (diff < 7*864e5) months[mk].active7++;
        }
      }
      const sorted = Object.entries(months).sort((a, b) => a[0].localeCompare(b[0]));
      if (sorted.length) {
        cg.innerHTML = `<table class="w-full"><thead><tr class="text-text-secondary"><th class="px-2 py-1 text-left">Μήνας</th><th class="px-2 py-1">Εγγραφές</th><th class="px-2 py-1">Active 30η</th><th class="px-2 py-1">Active 7η</th><th class="px-2 py-1">Retention 30η</th></tr></thead><tbody>${sorted.map(([k, v]) => { const r = v.total ? Math.round(v.active30/v.total*100) : 0; const bg = r > 70 ? "bg-green-100" : r > 40 ? "bg-amber-100" : "bg-red-100"; return `<tr class="${bg}"><td class="px-2 py-1 font-semibold">${k}</td><td class="px-2 py-1 text-center">${v.total}</td><td class="px-2 py-1 text-center">${v.active30}</td><td class="px-2 py-1 text-center">${v.active7}</td><td class="px-2 py-1 text-center font-bold">${r}%</td></tr>`; }).join("")}</tbody></table>`;
      } else cg.innerHTML = '<p class="text-text-muted">Δεν υπάρχουν δεδομένα.</p>';
    }

    // #5 Churn risk
    const cl = $("churn-list"); if (cl) {
      const now = Date.now();
      const atRisk = allGrants.filter((g) => g.tier !== "free" && g.status === "active" && g.last_sign_in_at && (now - new Date(g.last_sign_in_at).getTime() > 30*864e5));
      const neverLogged = allGrants.filter((g) => g.tier !== "free" && g.status === "active" && !g.last_sign_in_at);
      const items = [...neverLogged.map((g) => ({ ...g, risk: "never" })), ...atRisk.map((g) => ({ ...g, risk: "inactive" }))];
      cl.innerHTML = items.length ? items.map((g) => `<div class="flex items-center justify-between rounded-lg border ${g.risk === "never" ? "border-red-200 bg-red-50" : "border-amber-200 bg-amber-50"} px-3 py-2"><div><span class="font-semibold">${esc(g.email)}</span> <span class="ml-2">${tierBadge(g.tier)}</span></div><span class="text-xs ${g.risk === "never" ? "text-red-700 font-semibold" : "text-amber-700"}">${g.risk === "never" ? "Ποτέ login" : `${Math.floor((Date.now()-new Date(g.last_sign_in_at).getTime())/864e5)}η χωρίς login`}</span></div>`).join("") : '<p class="text-text-muted">Κανένας at-risk χρήστης.</p>';
    }
  }

  // ══════════════════════════════════════════════════════
  // TAB: OPERATIONS (#7 Health, #8 Announcements, #9 Flags, #6 Trials)
  // ══════════════════════════════════════════════════════

  async function loadOps(t) {
    // #7 Health
    try {
      const h = await api("/api/admin/saas?type=health", t);
      const hg = $("health-grid"); if (hg) {
        const items = [{ l: "Auth Users", v: h.auth_users || 0 }, ...Object.entries(h.tables || {}).map(([k, v]) => ({ l: k.replace("admin_", "").replace(/_/g, " "), v }))];
        hg.innerHTML = items.map((i) => `<div class="rounded-lg border border-border-light bg-sand/30 px-4 py-3 text-center"><p class="text-xl font-bold text-charcoal">${i.v}</p><p class="text-xs text-text-secondary capitalize">${i.l}</p></div>`).join("");
      }
    } catch {}

    // #8 Announcements
    loadAnnouncements(t);

    // #9 Feature flags
    loadFlags(t);

    // #6 Trials
    renderTrials();
  }

  async function loadAnnouncements(t) {
    try {
      const anns = await api("/api/admin/saas?type=announcements", t);
      const al = $("ann-list"); if (al) {
        al.innerHTML = Array.isArray(anns) && anns.length ? anns.map((a) => `<div class="flex items-center justify-between rounded-lg border ${a.active ? "border-green-200 bg-green-50/50" : "border-border-light bg-sand/20"} px-4 py-3"><div><span class="font-semibold text-sm">${esc(a.title)}</span><span class="ml-2 rounded px-1.5 py-0.5 text-xs ${a.type === "warning" ? "bg-amber-100 text-amber-700" : a.type === "maintenance" ? "bg-red-100 text-red-700" : "bg-blue-100 text-blue-700"}">${a.type}</span><p class="text-xs text-text-secondary mt-0.5">${esc(a.message).slice(0, 80)}</p></div><button data-ann-id="${a.id}" data-ann-active="${a.active}" class="ann-toggle rounded px-2 py-1 text-xs font-semibold ${a.active ? "text-red-600 hover:bg-red-50" : "text-green-600 hover:bg-green-50"}">${a.active ? "Απενεργοποίηση" : "Ενεργοποίηση"}</button></div>`).join("") : '<p class="text-text-muted text-xs">Κανένα announcement.</p>';
      }
    } catch {}
  }

  $("ann-list")?.addEventListener("click", async (e) => {
    const btn = e.target instanceof Element ? e.target.closest(".ann-toggle") : null; if (!btn) return;
    const id = btn.getAttribute("data-ann-id"), active = btn.getAttribute("data-ann-active") === "true";
    const t = await tok(); if (!t) return;
    try { await api("/api/admin/saas?type=announcements", t, { method: "POST", body: JSON.stringify({ id, active: !active }) }); loadAnnouncements(t); } catch {}
  });

  $("ann-create")?.addEventListener("click", async () => {
    const title = iv("ann-title"), message = iv("ann-message"), type = iv("ann-type");
    if (!title || !message) { showStatus("Τίτλος + μήνυμα απαιτούνται.", "error"); return; }
    const t = await tok(); if (!t) return;
    try { await api("/api/admin/saas?type=announcements", t, { method: "POST", body: JSON.stringify({ title, message, type }) }); sv("ann-title", ""); sv("ann-message", ""); loadAnnouncements(t); showStatus("Announcement δημιουργήθηκε.", "success"); } catch (e) { showStatus(e.message, "error"); }
  });

  async function loadFlags(t) {
    try {
      const flags = await api("/api/admin/saas?type=flags", t);
      const fl = $("flags-list"); if (fl) {
        fl.innerHTML = Array.isArray(flags) && flags.length ? flags.map((f) => `<div class="flex items-center justify-between rounded-lg border border-border-light px-4 py-3"><div><code class="text-sm font-semibold text-charcoal">${esc(f.flag_key)}</code><span class="ml-2 text-xs text-text-muted">${esc(f.description)}</span>${f.allowed_tiers?.length ? `<span class="ml-2 text-xs text-text-secondary">[${f.allowed_tiers.join(",")}]</span>` : ""}</div><button data-flag-key="${esc(f.flag_key)}" data-flag-enabled="${f.enabled}" class="flag-toggle rounded px-3 py-1 text-xs font-semibold ${f.enabled ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500"}">${f.enabled ? "ON" : "OFF"}</button></div>`).join("") : '<p class="text-text-muted text-xs">Κανένα flag.</p>';
      }
    } catch {}
  }

  $("flags-list")?.addEventListener("click", async (e) => {
    const btn = e.target instanceof Element ? e.target.closest(".flag-toggle") : null; if (!btn) return;
    const key = btn.getAttribute("data-flag-key"), enabled = btn.getAttribute("data-flag-enabled") === "true";
    const t = await tok(); if (!t) return;
    try { await api("/api/admin/saas?type=flags", t, { method: "POST", body: JSON.stringify({ flag_key: key, enabled: !enabled }) }); loadFlags(t); } catch {}
  });

  $("flag-create")?.addEventListener("click", async () => {
    const key = iv("flag-key"), desc = iv("flag-desc");
    if (!key) { showStatus("Flag key απαιτείται.", "error"); return; }
    const t = await tok(); if (!t) return;
    try { await api("/api/admin/saas?type=flags", t, { method: "POST", body: JSON.stringify({ flag_key: key, description: desc, enabled: false }) }); sv("flag-key", ""); sv("flag-desc", ""); loadFlags(t); showStatus("Flag δημιουργήθηκε.", "success"); } catch (e) { showStatus(e.message, "error"); }
  });

  function renderTrials() {
    const tl = $("trial-list"); if (!tl) return;
    const now = Date.now();
    const trials = allGrants.filter((g) => g.tier !== "free" && g.expires_at).map((g) => ({ ...g, diff: new Date(g.expires_at).getTime() - now })).sort((a, b) => a.diff - b.diff);
    const expired = trials.filter((t) => t.diff < 0);
    const soon = trials.filter((t) => t.diff >= 0 && t.diff < 14*864e5);
    const items = [...expired, ...soon];
    tl.innerHTML = items.length ? items.map((g) => `<div class="flex items-center justify-between rounded-lg border ${g.diff < 0 ? "border-red-200 bg-red-50" : "border-amber-200 bg-amber-50"} px-3 py-2"><div><span class="font-semibold text-sm">${esc(g.email)}</span> ${tierBadge(g.tier)}</div><span class="text-xs font-semibold ${g.diff < 0 ? "text-red-700" : "text-amber-700"}">${g.diff < 0 ? `Ληγμένο ${Math.abs(Math.ceil(g.diff/864e5))}η` : `Λήγει σε ${Math.ceil(g.diff/864e5)}η`}</span></div>`).join("") : '<p class="text-text-muted text-xs">Κανένα trial.</p>';
  }

  // ══════════════════════════════════════════════════════
  // TAB: SUPPORT (#9 Tickets, #10 Impersonate, #13 GDPR, #12 Anomaly)
  // ══════════════════════════════════════════════════════

  async function loadSupport(t) {
    loadTickets(t);
    renderAnomalies();
  }

  async function loadTickets(t) {
    try {
      const tickets = await api("/api/admin/saas?type=tickets", t);
      const tl = $("ticket-list"); if (tl) {
        const priC = { high: "border-red-200 bg-red-50", normal: "border-border-light bg-white/70", low: "border-gray-200 bg-gray-50" };
        const stC = { open: "bg-amber-100 text-amber-700", in_progress: "bg-blue-100 text-blue-700", resolved: "bg-green-100 text-green-700" };
        tl.innerHTML = Array.isArray(tickets) && tickets.length ? tickets.map((t) => `<div class="flex items-center justify-between rounded-lg border ${priC[t.priority]||priC.normal} px-4 py-3"><div><span class="font-semibold text-sm">${esc(t.user_email)}</span><span class="ml-2 text-sm text-text-secondary">${esc(t.subject)}</span><span class="ml-2 rounded px-1.5 py-0.5 text-xs ${stC[t.status]||""}">${t.status}</span></div><div class="flex gap-1">${t.status !== "resolved" ? `<button data-ticket-id="${t.id}" data-ticket-status="${t.status === "open" ? "in_progress" : "resolved"}" class="ticket-status rounded px-2 py-1 text-xs font-semibold text-gold hover:bg-gold/10">${t.status === "open" ? "In Progress" : "Resolve"}</button>` : ""}</div></div>`).join("") : '<p class="text-text-muted text-xs">Κανένα ticket.</p>';
      }
    } catch {}
  }

  $("ticket-list")?.addEventListener("click", async (e) => {
    const btn = e.target instanceof Element ? e.target.closest(".ticket-status") : null; if (!btn) return;
    const id = btn.getAttribute("data-ticket-id"), status = btn.getAttribute("data-ticket-status");
    const t = await tok(); if (!t) return;
    try { await api("/api/admin/saas?type=tickets", t, { method: "POST", body: JSON.stringify({ id, status }) }); loadTickets(t); } catch {}
  });

  $("ticket-create")?.addEventListener("click", async () => {
    const email = iv("ticket-email"), subject = iv("ticket-subject"), priority = iv("ticket-priority");
    if (!email || !subject) { showStatus("Email + θέμα.", "error"); return; }
    const t = await tok(); if (!t) return;
    try { await api("/api/admin/saas?type=tickets", t, { method: "POST", body: JSON.stringify({ user_email: email, subject, priority }) }); sv("ticket-email", ""); sv("ticket-subject", ""); loadTickets(t); showStatus("Ticket δημιουργήθηκε.", "success"); } catch (e) { showStatus(e.message, "error"); }
  });

  // #10 Impersonate
  $("impersonate-btn")?.addEventListener("click", () => {
    const email = iv("impersonate-email").toLowerCase(); if (!email) return;
    const g = allGrants.find((x) => x.email?.toLowerCase() === email);
    const ir = $("impersonate-result"); if (!ir) return;
    if (!g) { ir.innerHTML = `<p class="text-red-700">Ο χρήστης ${esc(email)} δεν βρέθηκε.</p>`; ir.classList.remove("hidden"); return; }
    const tier = g.tier || "free";
    const features = { free: ["2 books", "Basic dashboard"], solo: ["Unlimited books", "Receipt photos", "Excel export"], pro: ["Everything in Solo", "Recurring", "VAT", "Forecast", "Priority support"], team: ["Everything in Pro", "Multi-user", "Shared categories", "Admin panel"] };
    ir.innerHTML = `<div class="space-y-2"><p class="font-semibold">${esc(g.email)}</p><p>Tier: ${tierBadge(tier)} &nbsp; Status: ${statusBadge(g.status)}</p><p class="text-xs text-text-muted">Εγγραφή: ${fmtD(g.user_created_at)} &nbsp; Τελ. login: ${fmtDT(g.last_sign_in_at) || "Ποτέ"}</p><p class="text-xs text-text-muted">Λήξη: ${g.expires_at ? fmtD(g.expires_at) : "Χωρίς"}</p><div class="mt-2"><p class="text-xs font-semibold text-text-secondary mb-1">Features enabled:</p><ul class="list-disc list-inside text-xs text-text-secondary">${(features[tier]||[]).map((f) => `<li>${f}</li>`).join("")}</ul></div></div>`;
    ir.classList.remove("hidden");
  });

  // #13 GDPR export
  $("gdpr-btn")?.addEventListener("click", async () => {
    const email = iv("gdpr-email"); if (!email) return;
    const t = await tok(); if (!t) return;
    showStatus(`Exporting data for ${email}...`);
    try {
      const data = await api(`/api/admin/saas?type=export&email=${encodeURIComponent(email)}`, t);
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
      const a = document.createElement("a"); a.href = URL.createObjectURL(blob); a.download = `gdpr-${email}-${new Date().toISOString().slice(0,10)}.json`; a.click();
      showStatus("GDPR export ολοκληρώθηκε.", "success");
    } catch (e) { showStatus(e.message, "error"); }
  });

  // #12 Login anomalies
  function renderAnomalies() {
    const al = $("anomaly-list"); if (!al) return;
    const now = Date.now();
    const anomalies = [];
    for (const g of allGrants) {
      if (!g.last_sign_in_at && g.user_created_at) {
        const age = now - new Date(g.user_created_at).getTime();
        if (age > 7*864e5) anomalies.push({ email: g.email, tier: g.tier, type: "Ποτέ login", severity: "high", detail: `Εγγραφή ${fmtD(g.user_created_at)}, ποτέ login` });
      } else if (g.last_sign_in_at && g.user_created_at) {
        const loginDiff = new Date(g.last_sign_in_at).getTime() - new Date(g.user_created_at).getTime();
        if (loginDiff < 6e4) anomalies.push({ email: g.email, tier: g.tier, type: "Μόνο 1 login", severity: "medium", detail: `Login μόνο κατά την εγγραφή` });
      }
    }
    al.innerHTML = anomalies.length ? anomalies.map((a) => `<div class="flex items-center justify-between rounded-lg border ${a.severity === "high" ? "border-red-200 bg-red-50" : "border-amber-200 bg-amber-50"} px-3 py-2"><div><span class="font-semibold text-sm">${esc(a.email)}</span> ${tierBadge(a.tier)}</div><span class="text-xs ${a.severity === "high" ? "text-red-700" : "text-amber-700"}">${esc(a.detail)}</span></div>`).join("") : '<p class="text-text-muted text-xs">Κανένα anomaly.</p>';
  }

  // ══════════════════════════════════════════════════════
  // Session, auto-refresh, keyboard, auth
  // ══════════════════════════════════════════════════════

  function startSessionCheck() { stopSessionCheck(); sessionCheckInterval = setInterval(async () => { const { data } = await supabase.auth.getSession(); const s = data.session; if (!s) { showLoginPanel(); return; } const rem = s.expires_at*1000 - Date.now(); if (rem < 12e4 && rem > 0) $("session-warning")?.classList.remove("hidden"); else $("session-warning")?.classList.add("hidden"); }, 3e4); }
  function stopSessionCheck() { if (sessionCheckInterval) { clearInterval(sessionCheckInterval); sessionCheckInterval = null; } $("session-warning")?.classList.add("hidden"); }
  $("refresh-session")?.addEventListener("click", async () => { const { error } = await supabase.auth.refreshSession(); if (!error) { $("session-warning")?.classList.add("hidden"); showStatus("Session OK.", "success"); } });

  function startAutoRefresh() { stopAutoRefresh(); autoRefreshInterval = setInterval(() => { loadGrants(); loadAuditLog(); }, 3e4); }
  function stopAutoRefresh() { if (autoRefreshInterval) { clearInterval(autoRefreshInterval); autoRefreshInterval = null; } }
  $("auto-refresh-toggle")?.addEventListener("change", () => { if ($("auto-refresh-toggle") instanceof HTMLInputElement && $("auto-refresh-toggle").checked) { startAutoRefresh(); showStatus("Live: 30\"", "info"); } else stopAutoRefresh(); });

  // Keyboard shortcuts
  document.addEventListener("keydown", (e) => { if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement || e.target instanceof HTMLSelectElement) return; if (!$("grant-panel") || $("grant-panel").classList.contains("hidden")) return; if (e.key === "n" && adminRole === "admin") { e.preventDefault(); resetForm(); $("grant-email")?.focus(); } if (e.key === "s" || e.key === "/") { e.preventDefault(); $("grants-search")?.focus(); } if (e.key === "Escape") { $("user-audit-panel")?.classList.add("hidden"); $("impersonate-result")?.classList.add("hidden"); } if (e.key === "r") { e.preventDefault(); loadGrants(); loadAuditLog(); } });

  // Auth
  async function checkSession() { const t = await tok(); if (!t) { showLoginPanel(); return; } try { const me = await api("/api/admin/me", t); showGrantPanel(me.email, me.role); } catch { await supabase.auth.signOut(); showLoginPanel(); showStatus("Δεν υπάρχει admin πρόσβαση.", "error"); } }

  async function init() { try { const cfg = await (await fetch("/api/admin/config")).json(); supabase = createClient(cfg.supabaseUrl, cfg.supabasePublishableKey); await checkSession(); } catch (e) { showStatus(e.message || "Σφάλμα.", "error"); } }

  $("login-form")?.addEventListener("submit", async (e) => { e.preventDefault(); showStatus("Σύνδεση..."); const { error } = await supabase.auth.signInWithPassword({ email: iv("login-email"), password: iv("login-password") }); if (error) { showStatus("Αποτυχία σύνδεσης.", "error"); return; } await checkSession(); });

  $("grant-form")?.addEventListener("submit", async (e) => {
    e.preventDefault(); const em = iv("grant-email"), ti = iv("grant-tier").toUpperCase(), sr = iv("grant-source");
    if (!confirm(`${ti} → ${em} (${sr});`)) return;
    showStatus("Αποθήκευση..."); const t = await tok(); if (!t) { showLoginPanel(); return; }
    const ev = iv("grant-expires"), ea = ev ? new Date(ev).toISOString() : null;
    const notify = $("grant-notify") instanceof HTMLInputElement && $("grant-notify").checked;
    try { const r = await api("/api/admin/grant-session", t, { method: "POST", body: JSON.stringify({ email: iv("grant-email"), tier: iv("grant-tier"), source: iv("grant-source"), expiresAt: ea, reason: iv("grant-reason")||null, notify }) });
      const nm = notify ? (r.notified ? " — email OK" : " — email skip") : ""; showStatus(`${r.email} → ${r.tier}${nm}`, "success"); resetForm(); loadGrants(); loadAuditLog(); } catch (e) { showStatus(e.message, "error"); }
  });

  $("refresh-grants")?.addEventListener("click", loadGrants);
  $("refresh-audit")?.addEventListener("click", loadAuditLog);
  $("sign-out")?.addEventListener("click", async () => { await supabase.auth.signOut(); showLoginPanel(); showStatus("Αποσύνδεση."); });

  init();
</script>
